  fhir:PlanDefinition.description [ fhir:value "IMMZ.D2.DT.Hepatitis B.Birth dose\nBirth dose administration"] ;
  fhir:PlanDefinition.relatedArtifact [
     fhir:index 0 ;
     fhir:RelatedArtifact.type [ fhir:value "citation" ] ;
