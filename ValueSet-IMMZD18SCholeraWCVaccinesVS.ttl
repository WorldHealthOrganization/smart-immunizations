  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZD18SCholeraWCVaccinesVS</b></p><a name=\"IMMZD18SCholeraWCVaccinesVS\"> </a><a name=\"hcIMMZD18SCholeraWCVaccinesVS\"> </a><p>This value set expansion contains 8 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Child's|20birth|20and|20no|20cholera|20doses|20have|20been|20administered-134\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Child.39sbirthandnocholeradoseshavebeenadministered-134\">Child's birth and no cholera doses have been administered-134</a></td><td>Child's birth and no cholera doses have been administered</td><td><div><p>Child's birth AND Count of vaccines administered (where \"Vaccine type\" = \"Cholera vaccines\" and \"Type of dose\" = \"Primary series\") = 0</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-First|20cholera|20dose|20was|20administered-107\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Firstcholeradosewasadministered-107\">First cholera dose was administered-107</a></td><td>First cholera dose was administered</td><td><div><p>'Latest \"Dose number\" (where \"Vaccine type\" = \"Cholera vaccines\" and \"Type of dose\" = \"Primary series\") = 1</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-First|20cholera|20dose|20administered-105\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Firstcholeradoseadministered-105\">First cholera dose administered-105</a></td><td>First cholera dose administered</td><td><div><p>Latest \"Dose number\" (where \"Vaccine type\" = \"Cholera vaccines\"and \"Type of dose\" = \"Primary series\") = 1</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20primary|20series|20has|20been|20completed-93\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theprimaryserieshasbeencompleted-93\">The primary series has been completed-93</a></td><td>The primary series has been completed</td><td><div><p>\"Completed the primary vaccination series\" = TRUE (where \"Vaccine type\" = \"Typhoid vaccines\")</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Primary|20series|20for|20cholera|20has|20been|20completed|20and|20latest|20cholera|20dose|20was|20administered|20more|20than|203|20years|20ago-204\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Primaryseriesforcholerahasbeencompletedandlatestcholeradosewasadministeredmorethan3yearsago-204\">Primary series for cholera has been completed and latest cholera dose was administered more than 3 years ago-204</a></td><td>Primary series for cholera has been completed and latest cholera dose was administered more than 3 years ago</td><td><div><p>\"Completed the primary vaccination series\" (where \"Vaccine type\" = \"Cholera vaccines\") = TRUE AND Today's date − latest \"Date and time of vaccination\" (where \"Vaccine type\" = \"Cholera vaccines\") ≥ 3 years</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-First|20cholera|20booster|20dose|20was|20administered-105\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Firstcholeraboosterdosewasadministered-105\">First cholera booster dose was administered-105</a></td><td>First cholera booster dose was administered</td><td><div><p>'Latest \"Dose number\" (where \"Vaccine type\" = \"Cholera vaccines\" and \"Type of dose\" = \"Booster dose\") = 1</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-First|20cholera|20booster|20dose|20administered-103\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Firstcholeraboosterdoseadministered-103\">First cholera booster dose administered-103</a></td><td>First cholera booster dose administered</td><td><div><p>Latest \"Dose number\" (where \"Vaccine type\" = \"Cholera vaccines\"and \"Type of dose\" = \"Booster dose\") = 1</p>\n</div></td></tr><tr><td><a name=\"IMMZD18SCholeraWCVaccinesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Revaccination|20with|20booster|20series|20has|20been|20completed|20in|20the|20last|203|20years-191\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Revaccinationwithboosterserieshasbeencompletedinthelast3years-191\">Revaccination with booster series has been completed in the last 3 years-191</a></td><td>Revaccination with booster series has been completed in the last 3 years</td><td><div><p>\"Completed the booster series\" (where \"Vaccine type\" = \"Cholera vaccines\") = TRUE AND Today's date − latest \"Date and time of vaccination\" (where \"Vaccine type\" = \"Cholera vaccine\") &lt; 3 years</p>\n</div></td></tr></table></div>"
