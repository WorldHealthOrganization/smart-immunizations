         fhir:value [
           a fhir:String ;
           fhir:v "Client is not due for bOPV vaccination Guidance"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is not due for bOPV vaccination Guidance\n@guidance: Should not vaccinate client with first bOPV dose as client's age is less than 6 weeks. \nCheck for any other vaccines due and inform the caregiver of when to come back for the first bOPV dose.\n*/\ndefine \"Client is not due for bOPV vaccination Guidance\":\n  'Should not vaccinate client with first bOPV dose as client\\'s age is less than 6 weeks. \nCheck for any other vaccines due and inform the caregiver of when to come back for the first bOPV dose.'"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 3
         ]
       ] ) ;
