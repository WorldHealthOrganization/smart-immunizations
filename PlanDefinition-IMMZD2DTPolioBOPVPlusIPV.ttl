  fhir:description [ fhir:v "IMMZ.D2.DT.Polio.bOPV plus IPV\n\"Bivalent oral polio vaccine (bOPV) plus inactivated polio vaccine (IPV)\" schedule (applicable for all countries)"] ; # 
  fhir:relatedArtifact ( [
