  fhir:PlanDefinition.description [ fhir:value "IMMZ.D2.DT.Polio.bOPV plus IPV\n\"Bivalent oral polio vaccine (bOPV) plus inactivated polio vaccine (IPV)\" schedule (applicable for all countries)"] ;
  fhir:PlanDefinition.relatedArtifact [
     fhir:index 0 ;
     fhir:RelatedArtifact.type [ fhir:value "citation" ] ;
     fhir:RelatedArtifact.citation [ fhir:value "WHO recommendations for routine immunization - summary tables (January 2025)" ]
  ] ;
  fhir:PlanDefinition.library [
     fhir:value "http://smart.who.int/immunizations/Library/IMMZD2DTPolioBOPVPlusIPVLogic" ;
     fhir:index 0 ;
     fhir:link <http://smart.who.int/immunizations/Library/IMMZD2DTPolioBOPVPlusIPVLogic>
