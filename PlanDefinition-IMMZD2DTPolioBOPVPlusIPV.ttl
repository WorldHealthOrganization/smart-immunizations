     fhir:citation [ fhir:v "WHO recommendations for routine immunization - summary tables (January 2025)" ]
  ] ) ; # 
  fhir:library ( [
     fhir:v "http://smart.who.int/immunizations/Library/IMMZD2DTPolioBOPVPlusIPVLogic"^^xsd:anyURI ;
