         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is due for bOPV and IPV vaccination\n@pseudocode: \"Immunization recommendation status\" = \"Due\" (where \"Type of poliovirus dose\" = \"bOPV\") AND (where \"Type of poliovirus dose\" = \"IPV\")\n*/\ndefine \"Client is due for bOPV and IPV vaccination\":\n  \"Client is due for bOPV and IPV vaccination Case 1\"\n    or \"Client is due for bOPV and IPV vaccination Case 2\"\n    or \"Client is due for bOPV and IPV vaccination Case 3\"\n    or \"Client is due for bOPV and IPV vaccination Case 4\"\n    or \"Client is due for bOPV and IPV vaccination Case 5\"\n    or \"Client is due for bOPV and IPV vaccination Case 6\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
