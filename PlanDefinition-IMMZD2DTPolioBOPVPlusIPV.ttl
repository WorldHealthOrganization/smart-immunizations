         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Polio immunization schedule is complete\n@pseudocode: \"Immunization recommendation status\" = \"Complete\"\n\"Completed the primary vaccination series\" = TRUE (where \"Vaccine type\" = \"Poliovirus-containing vaccines\")\n*/\ndefine \"Polio immunization schedule is complete\":\n  Encounter.\"Five poliovirus primary series doses were administered\""
         ]
       ] [
         fhir:url [
