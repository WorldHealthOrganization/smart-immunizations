         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Client is due for bOPV and IPV vaccination Case 1"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is due for bOPV and IPV vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Due\" (where \"Type of poliovirus dose\" = \"bOPV\") AND (where \"Type of poliovirus dose\" = \"IPV\")\n*/\ndefine \"Client is due for bOPV and IPV vaccination Case 1\":\n  Encounter.\"No poliovirus primary series doses were administered\"\n    and Encounter.\"Client's age is more than 3 months\""
         ]
