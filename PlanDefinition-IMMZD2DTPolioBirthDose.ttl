         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Number of Polio Dose 0 Doses Administered" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@internal: Number of Polio Dose 0 Doses Administered\n*/\ndefine \"Number of Polio Dose 0 Doses Administered\":\n  Count(\"Polio Dose 0 Doses Administered to Patient\")" ]
       ], [
         fhir:index 3 ;
