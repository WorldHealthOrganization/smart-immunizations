         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is not due for the bOPV birth dose Case 2" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for the bOPV birth dose Case 2\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for the bOPV birth dose Case 2\":\n  Encounter.\"bOPV birth dose (a zero dose) was administered\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "13"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 14 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTPolioBirthDoseLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is not due for the bOPV birth dose" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for the bOPV birth dose\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for the bOPV birth dose\":\n  \"Client is not due for the bOPV birth dose Case 1\"\n    or \"Client is not due for the bOPV birth dose Case 2\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "14"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 15 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTPolioBirthDoseLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is not due for the bOPV birth dose Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for the bOPV birth dose Guidance\n@guidance = Should not vaccinate client with bOPV birth dose (a zero dose) as client's age is more than or equal to 1 week. Check for any other vaccines due and inform the caregiver of when to come back for the next dose.\n@guidance = Poliovirus birth dose was already administered. Check poliovirus immunization schedule.\n*/\ndefine \"Client is not due for the bOPV birth dose Guidance\":\n  case\n    when \"Client is not due for the bOPV birth dose Case 1\" then 'Should not vaccinate client with bOPV birth dose (a zero dose) as client\\'s age is more than or equal to 1 week. Check for any other vaccines due and inform the caregiver of when to come back for the next dose.'\n    when \"Client is not due for the bOPV birth dose Case 2\" then 'Poliovirus birth dose was already administered. Check poliovirus immunization schedule.'\n    else ''\n  end" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "15"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 16 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTPolioBirthDoseLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: Guidance\n*/\ndefine \"Guidance\":\n  case \n    when \"Client is due for the bOPV birth dose\" then \"Client is due for the bOPV birth dose Guidance\"\n    when \"Client is not due for the bOPV birth dose\" then \"Client is not due for the bOPV birth dose Guidance\" \n    else ''\n  end" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "16"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
