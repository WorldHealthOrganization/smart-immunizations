           fhir:v "IMMZD2DTJELiveRecombinantVaccineLogic"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Guidance"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: Guidance\n*/\ndefine \"Guidance\":\n  case \n    when \"Client is not due for JE vaccination\" then \"Client is not due for JE vaccination Guidance\"\n    when \"Client is due for JE vaccination\" then \"Client is due for JE vaccination Guidance\"\n    when \"JE immunization schedule is complete\" then \"JE immunization schedule is complete Guidance\" \n    else ''\n  end"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 26
         ]
       ] ) ;
