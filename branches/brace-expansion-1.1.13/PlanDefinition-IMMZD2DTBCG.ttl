       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Neonates born to women of unknown HIV status should be vaccinated as the benefits of BCG \n    vaccination outweigh the risks. Neonates of unknown HIV status born to HIV-infected women should be \n    vaccinated if they have no clinical evidence suggestive of HIV infection."
       ]
     ] ) ;
