           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: Meningococcal dose 1 Due Date\n@pseudocode: \"Date of birth\" + 2 years\n*/\ndefine \"Meningococcal dose 1 Due Date\":\n  if \"Meningococcal dose 1\" then Patient.birthDate + 2 years\n  else null"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
