           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: MCV dose 1 (MCV1) Due Date\n@pseudocode: \"Date of birth\" + 12 months\n*/\ndefine \"MCV dose 1 (MCV1) Due Date\":\n  if \"MCV dose 1 (MCV1)\" then Patient.birthDate + 12 months\n  else null"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
