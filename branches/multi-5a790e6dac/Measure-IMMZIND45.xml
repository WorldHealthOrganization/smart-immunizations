  <th scope="row" rowspan="2" class="row-header">
    
      
      <a name="immzind45logic-initial-population"> </a>
    
    Logic Definition
  </th>

  <td class="content-container"><em>Library Name:</em> IMMZIND45Logic</td>

</tr>
<tr>

  <td>
    <pre style="border: none;" class="content-container highlight language-cql"><code class="language-cql">/*
 * As defined by Member State
 */
define &quot;Initial Population&quot;:
  Immunization.occurrence is not null
  and Immunization.occurrence.toInterval() starts during &quot;Measurement Period&quot;</code></pre>
  </td>

</tr>
        
<tr>
  <th scope="row" rowspan="2" class="row-header">
    
      
      <a name="immzind45logic-denominator"> </a>
    
