         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is due for pneumococcal vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Due\"\n*/\ndefine \"Client is due for pneumococcal vaccination Case 1\":\n  Encounter.\"No pneumococcal primary series doses were administered\"\n    and Encounter.\"The client's age is between 6 weeks and 5 years\""
         ]
       ] [
