           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is due for pneumococcal booster dose\n@pseudocode: \"Immunization recommendation status\" = \"Due\"\n*/\ndefine \"Client is due for pneumococcal booster dose\":\n  \"Client is due for pneumococcal booster dose Case 1\"\n    or \"Client is due for pneumococcal booster dose Case 2\""
         ]
       ] [
