         fhir:value [
           a fhir:String ;
           fhir:v "Client is not due for pneumococcal vaccination Case 1"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is not due for pneumococcal vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for pneumococcal vaccination Case 1\":\n  Encounter.\"The client's age is less than 6 weeks\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 2
