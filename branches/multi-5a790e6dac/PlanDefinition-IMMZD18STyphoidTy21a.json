      },
      {
        "url" : "name",
        "valueString" : "Typhoid Ty21a primary series"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@output: Typhoid Ty21a primary series\n@description: Provision of the typhoid Ty21a, 3-dose oral primary series immunization\n@trigger: Child's birth\n@pseudo: \n@triggerDate: \"Date of birth\"\n*/\ndefine \"Typhoid Ty21a primary series\":\n  Encounter.\"No typhoid primary series doses were administered\"\n  and not \"The primary series has been completed\""
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 16
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
      "extension" : [{
        "url" : "libraryName",
        "valueString" : "IMMZD18STyphoidTy21aLogic"
      },
      {
        "url" : "name",
        "valueString" : "Typhoid Ty21a primary series Due Date"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@dynamicValue: Typhoid Ty21a primary series Due Date\n@pseudocode: \"Date of birth\" + 6 years\n*/\ndefine \"Typhoid Ty21a primary series Due Date\":\n  if \"Typhoid Ty21a primary series\" then Patient.birthDate + 6 years\n  else null"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 17
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
      "extension" : [{
        "url" : "libraryName",
        "valueString" : "IMMZD18STyphoidTy21aLogic"
      },
      {
        "url" : "name",
        "valueString" : "Typhoid Ty21a primary series Create"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@output: Typhoid Ty21a primary series Create\n@create: Ty21a – 3-doses to be administered orally every second day from 6 years of age.\n*/\ndefine \"Typhoid Ty21a primary series Create\":\n  if \"Typhoid Ty21a primary series\"\n  then 'Ty21a – 3-doses to be administered orally every second day from 6 years of age.' + '\nDue Date: ' + ToString(\"Typhoid Ty21a primary series Due Date\")\n  else ''"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 18
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
      "extension" : [{
        "url" : "libraryName",
        "valueString" : "IMMZCommon"
      },
      {
        "url" : "name",
        "valueString" : "seriesPrimary"
      },
      {
        "url" : "statement",
        "valueString" : "/**\n * @description: Gets the doses from the primary series\n */\ndefine fluent function seriesPrimary(immunizations List<Immunization>):\n  immunizations I where\n    exists( I.protocolApplied pa where pa.series = 'Primary series' )"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 19
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
