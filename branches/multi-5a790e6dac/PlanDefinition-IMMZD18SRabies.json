        "valueString" : "Date of Latest Rabies Dose"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@internal: Date of Latest Rabies Dose\n*/\ndefine \"Date of Latest Rabies Dose\":\n  date from start of \"Rabies Doses Administered to Patient\".mostRecent().occurrence.toInterval()"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 13
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
      "extension" : [{
        "url" : "libraryName",
        "valueString" : "IMMZD18SRabiesLogic"
      },
      {
        "url" : "name",
        "valueString" : "Rabies dose 2 Due Date"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@dynamicValue: Rabies dose 2 Due Date\n@pseudocode: \"Date and time of vaccination\" (where \"Vaccine type\" = \"Rabies vaccines\") + 7 days\n*/\ndefine \"Rabies dose 2 Due Date\":\n  if \"Rabies dose 2\" then Encounter.\"Date of Latest Rabies Dose\" + 7 days\n  else null"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 14
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
