        "url" : "libraryName",
        "valueString" : "IMMZD18SRabiesLogic"
      },
      {
        "url" : "name",
        "valueString" : "Rabies dose 2 Create"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@output: Rabies dose 2 Create\n@create: Rabies dose 2 should be provided if previous dose was given more than 1 week ago\n*/\ndefine \"Rabies dose 2 Create\":\n  if \"Rabies dose 2\"\n  then 'Rabies dose 2 should be provided if previous dose was given more than 1 week ago' + '\nDue Date: ' + ToString(\"Rabies dose 2 Due Date\")\n  else ''"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 15
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
      "extension" : [{
