      {
        "url" : "name",
        "valueString" : "Rabies dose 1 Create"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@output: Rabies dose 1 Create\n@create: Rabies dose 1 should be provided if the client is at a high risk of rabies virus exposure\n*/\ndefine \"Rabies dose 1 Create\":\n  if \"Rabies dose 1\"\n  then 'Rabies dose 1 should be provided if the client is at a high risk of rabies virus exposure'\n  else ''"
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 12
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
