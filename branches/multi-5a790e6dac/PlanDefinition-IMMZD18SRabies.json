    },
    {
      "extension" : [{
        "url" : "libraryName",
        "valueString" : "IMMZD18SRabiesLogic"
      },
      {
        "url" : "name",
        "valueString" : "Rabies dose 1"
      },
      {
        "url" : "statement",
        "valueString" : "/*\n@output: Rabies dose 1\n@description: Provision of rabies dose 1\n@trigger: To be determined by Member States\n@pseudo: \n@triggerDate: To be determined by Member States\n*/\ndefine \"Rabies dose 1\":\n  Encounter.\"No rabies primary series doses were administered\"\n  and not \"First rabies dose from the primary series was administered\""
      },
      {
        "url" : "displaySequence",
        "valueInteger" : 8
      }],
      "url" : "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"
    },
    {
      "extension" : [{
        "url" : "libraryName",
        "valueString" : "IMMZD2DTRabiesEncounterElements"
