         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is not due for rabies vaccination\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for rabies vaccination\":\n  Encounter.\"One rabies primary series doses were administered\"\n    and Encounter.\"The latest rabies dose was administered less than 7 days ago\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
