         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@input: The latest rabies dose was administered more than 7 days ago\n@pseudocode: ''Today's date - Latest \"Date of vaccination\" (where \"Vaccine type\" = \"Rabies vaccines\") ≥ 7 days\n@code: The latest rabies dose was administered more than 7 days ago-97\n@decision: IMMZ.D2.DT.Rabies: Pre-exposure prophylaxis (PrEP), 2-dose scheme; high risk of rabies virus exposure\n*/\ndefine \"The latest rabies dose was administered more than 7 days ago\":\n  not \"The latest rabies dose was administered less than 7 days ago\""
