  fhir:description [ fhir:v "IMMZ.D2.DT.Rabies\nPre-exposure prophylaxis (PrEP), 2-dose scheme; high risk of rabies virus exposure"] ; # 
  fhir:relatedArtifact ( [
     fhir:type [ fhir:v "citation" ] ;
     fhir:citation [ fhir:v "WHO recommendations for routine immunization - summary tables (January 2025)" ]
  ] ) ; # 
  fhir:library ( [
     fhir:v "http://smart.who.int/immunizations/Library/IMMZD2DTRabiesLogic"^^xsd:anyURI ;
