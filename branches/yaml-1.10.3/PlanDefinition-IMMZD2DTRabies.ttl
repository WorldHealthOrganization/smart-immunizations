         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@internal: Rabies containing Doses Administered to Patient that are in the Primary series\n*/\ndefine \"Rabies Primary Series Doses Administered to Patient\":\n  \"Rabies Doses Administered to Patient\".seriesPrimary()"
