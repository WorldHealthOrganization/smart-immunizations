         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: Malaria dose 1 Due Date\n@pseudocode: \"Date of birth\" + 5 months\n*/\ndefine \"Malaria dose 1 Due Date\":\n  if \"Malaria dose 1\" then Patient.birthDate + 5 months\n  else null"
