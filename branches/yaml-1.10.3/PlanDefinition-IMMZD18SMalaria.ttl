         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: Malaria dose 2 Due Date\n@pseudocode: \"Date and time of vaccination\" (where \"Vaccine type\" = \"Malaria vaccines\") + 4 weeks\n*/\ndefine \"Malaria dose 2 Due Date\":\n  if \"Malaria dose 2\" then Encounter.\"Date of Latest Malaria Dose\" + 4 weeks\n  else null"
         ]
       ] [
         fhir:url [
