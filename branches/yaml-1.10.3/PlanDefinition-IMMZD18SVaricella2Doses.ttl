           a fhir:String ;
           fhir:v "Varicella dose 2"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Varicella dose 2\n@description: Provision of the varicella dose 2\n@trigger: First varicella dose from the primary series was administered\n@pseudo: Count of vaccines administered (where \"Vaccine type\" = \"Varicella-containing vaccines\" and \"Type of dose\" = \"Primary series\") =1\n@triggerDate: \"Date and time of vaccination\" (where \"Vaccine type\" = \"Varicella-containing vaccines\")\n*/\ndefine \"Varicella dose 2\":\n  \"First varicella dose from the primary series was administered\"\n  and not \"Second varicella dose from the primary series was administered. The primary series has been completed\""
         ]
       ] [
