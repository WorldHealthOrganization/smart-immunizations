         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@internal: Varicella containing Doses Administered to Patient that are in the Primary series\n*/\ndefine \"Varicella Primary Series Doses Administered to Patient\":\n  \"Varicella Doses Administered to Patient\".seriesPrimary()"
         ]
