           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/**\n * @description: Gets a given immunization from a list that matches the dose number\n */\ndefine fluent function getDose(immunizations List<Immunization>, doseNumber String):\n  immunizations I where\n    exists( I.protocolApplied pa where pa.doseNumber = doseNumber )"
         ]
