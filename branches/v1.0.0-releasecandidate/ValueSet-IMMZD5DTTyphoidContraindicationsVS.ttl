  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZD5DTTyphoidContraindicationsVS</b></p><a name=\"IMMZD5DTTyphoidContraindicationsVS\"> </a><a name=\"hcIMMZD5DTTyphoidContraindicationsVS\"> </a><p>This value set expansion contains 8 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20has|20hypersensitivity|20to|20any|20component|20of|20the|20vaccine-72\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclienthashypersensitivitytoanycomponentofthevaccine-72\">The client has hypersensitivity to any component of the vaccine-72</a></td><td>The client has hypersensitivity to any component of the vaccine</td><td><div><p>\"Potential contraindications\" = \"Hypersensitivity to vaccine components\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Typhoid|20vaccination|20could|20be|20contraindicated.|20Clinical|20judgement|20is|20required.|20Create|20a|20clinical|20note.-66\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Typhoidvaccinationcouldbecontraindicated.46Clinicaljudgementisrequired.46Createaclinicalnote.46-66\">Typhoid vaccination could be contraindicated. Clinical judgement is required. Create a clinical note.-66</a></td><td>Typhoid vaccination could be contraindicated. Clinical judgement is required. Create a clinical note.</td><td><div><p>\"Immunization recommendation status\" = \"Further evaluation needed\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20is|20currently|20pregnant-52\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclientiscurrentlypregnant-52\">The client is currently pregnant-52</a></td><td>The client is currently pregnant</td><td><div><p>\"Potential contraindications\" = \"Currently pregnant\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Typhoid|20vaccination|20is|20contraindicated|20for|20Ty21a|20vaccine.|20Clinical|20judgement|20is|20required|20for|20Typbar-TCV|20or|20ViPS|20vaccine.|20Create|20a|20clinical|20note-224\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-TyphoidvaccinationiscontraindicatedforTy21avaccine.46ClinicaljudgementisrequiredforTypbar-TCVorViPSvaccine.46Createaclinicalnote-224\">Typhoid vaccination is contraindicated for Ty21a vaccine. Clinical judgement is required for Typbar-TCV or ViPS vaccine. Create a clinical note-224</a></td><td>Typhoid vaccination is contraindicated for Ty21a vaccine. Clinical judgement is required for Typbar-TCV or ViPS vaccine. Create a clinical note</td><td><div><p>\"Immunization recommendation status\" = \"Contraindicated\" (where \"Type of typhoid dose\" = \"Ty21a\") AND \"Immunization recommendation status\" = \"Further evaluation needed\" (where \"Type of typhoid dose\" = \"Typbar-TCV\" OR \"ViPS\")</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20is|20currently|20taking|20antibiotics-52\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclientiscurrentlytakingantibiotics-52\">The client is currently taking antibiotics-52</a></td><td>The client is currently taking antibiotics</td><td><div><p>\"Potential contraindications\" = \"Taking antibiotics\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Typhoid|20vaccination|20is|20contraindicated|20for|20Ty21a|20vaccine.-97\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-TyphoidvaccinationiscontraindicatedforTy21avaccine.46-97\">Typhoid vaccination is contraindicated for Ty21a vaccine.-97</a></td><td>Typhoid vaccination is contraindicated for Ty21a vaccine.</td><td><div><p>\"Immunization recommendation status\" = \"Contraindicated\" (where \"Type of typhoid dose\" = \"Ty21a\")</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client's|20HIV|20status|20is|20positive-29\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclient.39sHIVstatusispositive-29\">The client's HIV status is positive-29</a></td><td>The client's HIV status is positive</td><td><div><p>\"HIV status\" = \"HIV-positive\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTTyphoidContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20is|20not|20immunologically|20stable-31\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclientisnotimmunologicallystable-31\">The client is not immunologically stable-31</a></td><td>The client is not immunologically stable</td><td><div><p>\"Immunologically stable\" ≠ TRUE</p>\n</div></td></tr></table></div>"
