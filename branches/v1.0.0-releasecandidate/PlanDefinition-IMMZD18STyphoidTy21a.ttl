         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Typhoid booster dose(s) repeat 3-doses series Create" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Typhoid booster dose(s) repeat 3-doses series Create\n@create: Revaccination (3-doses) is recommended every 3–7 years for Ty21a.\n*/\ndefine \"Typhoid booster dose(s) repeat 3-doses series Create\":\n  if \"Typhoid booster dose(s) repeat 3-doses series\"\n  then 'Revaccination (3-doses) is recommended every 3–7 years for Ty21a.' + '\nDue Date: ' + ToString(\"Typhoid booster dose(s) repeat 3-doses series Due Date\") + '\nOverdue: ' + ToString(\"Typhoid booster dose(s) repeat 3-doses series Overdue\")\n  else ''" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "14"^^xsd:integer ]
