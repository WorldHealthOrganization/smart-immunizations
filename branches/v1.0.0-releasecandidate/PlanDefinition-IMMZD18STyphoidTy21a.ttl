         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: Typhoid booster dose(s) repeat 3-doses series Overdue\n@pseudocode: Latest \"Date and time of vaccination\" (where \"Vaccine type\" = \"Typhoid vaccines\") + 7 years\n*/\ndefine \"Typhoid booster dose(s) repeat 3-doses series Overdue\":\n  if \"Typhoid booster dose(s) repeat 3-doses series\" then Encounter.\"Date of Latest Typhoid Dose\" + 7 years\n  else null" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "13"^^xsd:integer ]
       ] ;
