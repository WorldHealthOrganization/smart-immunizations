         fhir:Extension.valueString [ fhir:value "Hepatitis B vaccination could be contraindicated. Clinical judgement is required. Create a clinical note. Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Hepatitis B vaccination could be contraindicated. Clinical judgement is required. Create a clinical note. Guidance\n@guidance: Do not vaccinate client with hepatitis B if the client had a history of serious allergic reactions to any of the vaccine components. Allergy to yeast is considered a contraindication to immunization with yeast-produced hepatitis B-containing vaccine.\n*/\ndefine \"Hepatitis B vaccination could be contraindicated. Clinical judgement is required. Create a clinical note. Guidance\":\n  'Do not vaccinate client with hepatitis B if the client had a history of serious allergic reactions to any of the vaccine components. Allergy to yeast is considered a contraindication to immunization with yeast-produced hepatitis B-containing vaccine.'" ]
