         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Consider MCV0. Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Consider MCV0. Guidance\n@guidance: May vaccinate client with MCV0 as client is within appropriate age range, MCV0 was not administered and no live vaccine was administered in the past 4 weeks. Check if one of the MCV0 specific scenarios is applicable.\n*/\ndefine \"Consider MCV0. Guidance\":\n  'May vaccinate client with MCV0 as client is within appropriate age range, MCV0 was not administered and no live vaccine was administered in the past 4 weeks. Check if one of the MCV0 specific scenarios is applicable.'" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "25"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
