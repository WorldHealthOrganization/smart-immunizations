         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTMeaslesMCVDose0Logic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is not due for MCV0 Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for MCV0 Guidance\n@guidance = Should not vaccinate client with MCV0 as client's age is less than 6 months. Check for any vaccines due and inform the caregiver of when to come back for MCV0.\n@guidance = Should not vaccinate client with MCV0 as live vaccine was administered in the past 4 weeks. Check for any vaccines due and inform the caregiver of when to come back for MCV0.\n@guidance = Should not vaccinate client with MCV0 as client's age is more than 9 months.\nCheck measles routine immunization schedule.\n@guidance = MCV0 was administered.\nCheck measles routine immunization schedule.\n*/\ndefine \"Client is not due for MCV0 Guidance\":\n  case\n    when \"Client is not due for MCV0 Case 1\" then 'Should not vaccinate client with MCV0 as client\\'s age is less than 6 months. Check for any vaccines due and inform the caregiver of when to come back for MCV0.'\n    when \"Client is not due for MCV0 Case 2\" then 'Should not vaccinate client with MCV0 as live vaccine was administered in the past 4 weeks. Check for any vaccines due and inform the caregiver of when to come back for MCV0.'\n    when \"Client is not due for MCV0 Case 3\" then 'Should not vaccinate client with MCV0 as client\\'s age is more than 9 months.\nCheck measles routine immunization schedule.'\n    when \"Client is not due for MCV0 Case 4\" then 'MCV0 was administered.\nCheck measles routine immunization schedule.'\n    else ''\n  end" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "21"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
