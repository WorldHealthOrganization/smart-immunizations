         fhir:Extension.valueString [ fhir:value "First DTP dose from the primary series was administered" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@complete: First DTP dose from the primary series was administered\n@pseudocode: Count of vaccines administered (where \"Vaccine type\" = \"DTP-containing vaccines\" and \"Type of dose\" = \"Primary series\") = 1\n*/\ndefine \"First DTP dose from the primary series was administered\":\n  Encounter.\"One DTP primary series dose was administered\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "48"^^xsd:integer ]
