<http://smart.who.int/immunizations/PlanDefinition/IMMZD18SDTPDelayedOrInterruptedSeries> a fhir:PlanDefinition ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:Resource.id [ fhir:value "IMMZD18SDTPDelayedOrInterruptedSeries"] ;
