  fhir:PlanDefinition.action [
     fhir:index 0 ;
     fhir:PlanDefinition.action.title [ fhir:value "DTP dose 1 (delayed start)" ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Provision of DTP dose 1 with a delayed start\nTrigger event: No DTP doses were administered and client's age is more than 1 year\nTrigger pseudo: Count of vaccines administered (where \"Vaccine type\" = \"DTP-containing vaccines\") = 0 AND Today's date − \"Date of birth\" > 1 year\nTrigger date: Date of birth\nCreate condition: For children whose vaccination series has been interrupted, the series should be resumed without repeating previous doses. Children aged 1 year to under 7 years who have not previously been vaccinated should receive 3 doses of vaccine following a 0, 1, 6 month schedule.\n\nIf tetanus vaccination is started during adolescence or adulthood, a total of only 5 appropriately spaced doses are required to obtain lifelong protection.\n\nPregnant women and their newborn infants are protected from birth-associated tetanus if the mother received 5 doses if first vaccinated during adolescence/adulthood." ] ;
     fhir:PlanDefinition.action.condition [
       fhir:index 0 ;
       fhir:PlanDefinition.action.condition.kind [ fhir:value "applicability" ] ;
       fhir:PlanDefinition.action.condition.expression [
