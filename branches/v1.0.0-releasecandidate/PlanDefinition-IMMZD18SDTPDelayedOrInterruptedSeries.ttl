         fhir:Extension.valueString [ fhir:value "Td Doses Administered to Patient" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@internal: Td Doses Administered to Patient\n*/\ndefine \"Td Doses Administered to Patient\":\n  DTPElements.\"Td Doses Administered to Patient\".onOrBefore(Today)" ]
       ], [
