     ], [
       fhir:value "http://hl7.org/fhir/uv/crmi/StructureDefinition/crmi-publishableplandefinition" ;
       fhir:index 2 ;
       fhir:link <http://hl7.org/fhir/uv/crmi/StructureDefinition/crmi-publishableplandefinition>
     ]
