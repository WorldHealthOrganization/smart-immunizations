         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: DTP dose 2 (delayed start) Due Date\n@pseudocode: Latest \"Date and time of vaccination\" (where \"Vaccine type\" = \"DTP-containing vaccines\") + 4 weeks\n*/\ndefine \"DTP dose 2 (delayed start) Due Date\":\n  if \"DTP dose 2 (delayed start)\" then Encounter.\"Date of Latest DTP Dose\" + 4 weeks\n  else null" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "50"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
