       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD18SDTPDelayedOrInterruptedSeriesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "DTP dose 1 (delayed start)" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: DTP dose 1 (delayed start)\n@description: Provision of DTP dose 1 with a delayed start\n@trigger: No DTP doses were administered and client's age is more than 1 year\n@pseudo: Count of vaccines administered (where \"Vaccine type\" = \"DTP-containing vaccines\") = 0 AND Today's date − \"Date of birth\" > 1 year\n@triggerDate: Date of birth\n*/\ndefine \"DTP dose 1 (delayed start)\":\n  Encounter.\"No DTP primary series doses were administered\"\n  and Encounter.\"Client's age is more than 1 year\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "44"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 45 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD18SDTPDelayedOrInterruptedSeriesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "DTP dose 1 (delayed start) Due Date" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: DTP dose 1 (delayed start) Due Date\n@pseudocode: As soon as possible\n*/\ndefine \"DTP dose 1 (delayed start) Due Date\":\n  if \"DTP dose 1 (delayed start)\" then Patient.birthDate + 1 year\n  else null" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "45"^^xsd:integer ]
