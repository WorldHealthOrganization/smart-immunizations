         fhir:Extension.valueString [ fhir:value "/*\n@internal: Date of Latest Td Dose\n*/\ndefine \"Date of Latest Td Dose\":\n  date from start of \"Td Doses Administered to Patient\".mostRecent().occurrence.toInterval()" ]
