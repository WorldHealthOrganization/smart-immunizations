     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZD2DTHepatitisAInactivatedHAV2DosesVS</b></p><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS\"> </a><a name=\"hcIMMZD2DTHepatitisAInactivatedHAV2DosesVS\"> </a><p>This value set expansion contains 10 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client's|20age|20is|20less|20than|2012|20months-42\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Client.39sageislessthan12months-42\">Client's age is less than 12 months-42</a></td><td>Client's age is less than 12 months</td><td><div><p>Today's date − \"Date of birth\" &lt; 12 months</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client|20is|20not|20due|20for|20Hepatitis|20A|20vaccination-48\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-ClientisnotdueforHepatitisAvaccination-48\">Client is not due for Hepatitis A vaccination-48</a></td><td>Client is not due for Hepatitis A vaccination</td><td><div><p>\"Immunization recommendation status\" = \"Not due\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-No|20hepatitis|20A|20primary|20series|20doses|20were|20administered-131\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-NohepatitisAprimaryseriesdoseswereadministered-131\">No hepatitis A primary series doses were administered-131</a></td><td>No hepatitis A primary series doses were administered</td><td><div><p>Count of vaccines administered (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\" and \"Type of dose\" = \"Primary series\") = 0</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client's|20age|20is|20more|20than|20or|20equal|20to|2012|20months-42\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Client.39sageismorethanorequalto12months-42\">Client's age is more than or equal to 12 months-42</a></td><td>Client's age is more than or equal to 12 months</td><td><div><p>Today's date − \"Date of birth\" ≥ 12 months</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client|20is|20due|20for|20Hepatitis|20A|20vaccination-44\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-ClientisdueforHepatitisAvaccination-44\">Client is due for Hepatitis A vaccination-44</a></td><td>Client is due for Hepatitis A vaccination</td><td><div><p>\"Immunization recommendation status\" = \"Due\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-One|20hepatitis|20A|20primary|20series|20dose|20was|20administered-131\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-OnehepatitisAprimaryseriesdosewasadministered-131\">One hepatitis A primary series dose was administered-131</a></td><td>One hepatitis A primary series dose was administered</td><td><div><p>Count of vaccines administered (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\" and \"Type of dose\" = \"Primary series\") = 1</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20latest|20Hepatitis|20A|20dose|20was|20administered|20less|20than|206|20months|20ago-115\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-ThelatestHepatitisAdosewasadministeredlessthan6monthsago-115\">The latest Hepatitis A dose was administered less than 6 months ago-115</a></td><td>The latest Hepatitis A dose was administered less than 6 months ago</td><td><div><p>Today's date − \"Date and time of vaccination\" (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\") &lt; 6 months</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20latest|20Hepatitis|20A|20dose|20was|20administered|20more|20than|206|20months|20ago-115\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-ThelatestHepatitisAdosewasadministeredmorethan6monthsago-115\">The latest Hepatitis A dose was administered more than 6 months ago-115</a></td><td>The latest Hepatitis A dose was administered more than 6 months ago</td><td><div><p>Today's date − \"Date and time of vaccination\" (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\") ≥ 6 months</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Two|20hepatitis|20A|20primary|20series|20doses|20were|20administered-131\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-TwohepatitisAprimaryseriesdoseswereadministered-131\">Two hepatitis A primary series doses were administered-131</a></td><td>Two hepatitis A primary series doses were administered</td><td><div><p>Count of vaccines administered (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\" and \"Type of dose\" = \"Primary series\") = 2</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTHepatitisAInactivatedHAV2DosesVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Hepatitis|20A|20immunization|20schedule|20is|20complete-158\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-HepatitisAimmunizationscheduleiscomplete-158\">Hepatitis A immunization schedule is complete-158</a></td><td>Hepatitis A immunization schedule is complete</td><td><div><p>\"Immunization recommendation status\" = \"Complete\"\n\"Completed the primary vaccination series\" = TRUE (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\")</p>\n</div></td></tr></table></div>"
