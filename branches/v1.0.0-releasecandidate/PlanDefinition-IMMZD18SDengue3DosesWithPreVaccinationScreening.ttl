         fhir:Extension.valueString [ fhir:value "Dengue Primary Series Doses Administered to Patient" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@internal: Dengue containing Doses Administered to Patient that are in the Primary series\n*/\ndefine \"Dengue Primary Series Doses Administered to Patient\":\n  \"Dengue Doses Administered to Patient\".seriesPrimary()" ]
       ], [
