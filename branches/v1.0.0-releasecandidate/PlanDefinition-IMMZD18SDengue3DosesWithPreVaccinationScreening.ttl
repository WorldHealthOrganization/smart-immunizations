       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@internal: Number of Dengue Primary Series doses\n*/\ndefine \"Number of Dengue Primary Series Doses Administered\":\n  Count(\"Dengue Primary Series Doses Administered to Patient\")" ]
       ], [
