         fhir:Extension.valueString [ fhir:value "/*\n@internal: Date of Latest Dengue Dose\n*/\ndefine \"Date of Latest Dengue Dose\":\n  date from start of \"Dengue Doses Administered to Patient\".mostRecent().occurrence.toInterval()" ]
