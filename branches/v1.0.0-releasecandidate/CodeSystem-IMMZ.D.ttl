     fhir:CodeSystem.concept.display [ fhir:value "Immunodeficiency syndromes" ] ;
     fhir:CodeSystem.concept.definition [ fhir:value "The client has  immunodeficiency syndromes (e.g. HIV/AIDS, known or suspected congenital immunodeficiency, leukaemia, lymphoma or other malignant disease)" ]
