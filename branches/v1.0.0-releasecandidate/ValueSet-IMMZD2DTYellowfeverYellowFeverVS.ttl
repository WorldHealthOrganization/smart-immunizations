  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZD2DTYellowfeverYellowFeverVS</b></p><a name=\"IMMZD2DTYellowfeverYellowFeverVS\"> </a><a name=\"hcIMMZD2DTYellowfeverYellowFeverVS\"> </a><p>This value set expansion contains 9 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-No|20yellow|20fever|20primary|20series|20doses|20were|20administered-121\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Noyellowfeverprimaryseriesdoseswereadministered-121\">No yellow fever primary series doses were administered-121</a></td><td>No yellow fever primary series doses were administered</td><td><div><p>Count of vaccines administered (where \"Vaccine type\" = \"Yellow fever vaccines\" and \"Type of dose\" = \"Primary series\") = 0</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client's|20age|20is|20less|20than|209|20months-41\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Client.39sageislessthan9months-41\">Client's age is less than 9 months-41</a></td><td>Client's age is less than 9 months</td><td><div><p>Today's date − \"Date of birth\" &lt; 9 months</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client|20is|20not|20due|20for|20yellow|20fever|20vaccination-48\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Clientisnotdueforyellowfevervaccination-48\">Client is not due for yellow fever vaccination-48</a></td><td>Client is not due for yellow fever vaccination</td><td><div><p>\"Immunization recommendation status\" = \"Not due\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client's|20age|20is|20more|20than|20or|20equal|20to|209|20months-41\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Client.39sageismorethanorequalto9months-41\">Client's age is more than or equal to 9 months-41</a></td><td>Client's age is more than or equal to 9 months</td><td><div><p>Today's date − \"Date of birth\" ≥ 9 months</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Live|20vaccine|20was|20administered|20in|20the|20past|204|20weeks-92\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Livevaccinewasadministeredinthepast4weeks-92\">Live vaccine was administered in the past 4 weeks-92</a></td><td>Live vaccine was administered in the past 4 weeks</td><td><div><p>Today's date − latest \"Date and time of vaccination\" (where \"Live vaccine\" = TRUE) &lt; 4 weeks</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-No|20live|20vaccine|20was|20administered|20in|20the|20past|204|20weeks-92\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Nolivevaccinewasadministeredinthepast4weeks-92\">No live vaccine was administered in the past 4 weeks-92</a></td><td>No live vaccine was administered in the past 4 weeks</td><td><div><p>Today's date − latest \"Date and time of vaccination\" (where \"Live vaccine\" = TRUE) ≥ 4 weeks</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client|20is|20due|20for|20yellow|20fever|20vaccination-44\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Clientisdueforyellowfevervaccination-44\">Client is due for yellow fever vaccination-44</a></td><td>Client is due for yellow fever vaccination</td><td><div><p>\"Immunization recommendation status\" = \"Due\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-One|20yellow|20fever|20primary|20series|20dose|20was|20administered-121\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Oneyellowfeverprimaryseriesdosewasadministered-121\">One yellow fever primary series dose was administered-121</a></td><td>One yellow fever primary series dose was administered</td><td><div><p>Count of vaccines administered (where \"Vaccine type\" = \"Yellow fever vaccines\" and \"Type of dose\" = \"Primary series\") = 1</p>\n</div></td></tr><tr><td><a name=\"IMMZD2DTYellowfeverYellowFeverVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Yellow|20fever|20immunization|20schedule|20is|20complete-148\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Yellowfeverimmunizationscheduleiscomplete-148\">Yellow fever immunization schedule is complete-148</a></td><td>Yellow fever immunization schedule is complete</td><td><div><p>\"Immunization recommendation status\" = \"Complete\"\n\"Completed the primary vaccination series\" = TRUE (where \"Vaccine type\" = \"Yellow fever vaccines\")</p>\n</div></td></tr></table></div>"
