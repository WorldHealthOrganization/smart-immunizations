           fhir:v "/*\n@internal: JE containing Doses Administered to Patient\n*/\ndefine \"JE Doses Administered to Patient\":\n  Encounter.\"Doses Administered to Patient\" I\n  where\n    I.vaccineCode in Concepts.\"JE vaccines\""
