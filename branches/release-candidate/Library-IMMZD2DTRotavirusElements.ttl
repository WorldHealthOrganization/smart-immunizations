     fhir:type [ fhir:v "boolean" ]
  ] [
     fhir:name [ fhir:v "One rotavirus primary series dose was administered" ] ;
     fhir:use [ fhir:v "out" ] ;
     fhir:min [ fhir:v 0 ] ;
     fhir:max [ fhir:v "1" ] ;
     fhir:type [ fhir:v "boolean" ]
  ] [
     fhir:name [ fhir:v "Two rotavirus primary series doses were administered" ] ;
     fhir:use [ fhir:v "out" ] ;
