     fhir:min [ fhir:v 0 ] ;
     fhir:max [ fhir:v "*" ] ;
     fhir:type [ fhir:v "Immunization" ]
  ] [
     fhir:name [ fhir:v "Rotavirus Primary Series Doses Administered to Patient" ] ;
     fhir:use [ fhir:v "out" ] ;
