  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n<div>\n    <table class=\"grid dict\">\n        \n        \n        <tr>\n            <th scope=\"row\"><b>Title: </b></th>\n            <td style=\"padding-left: 4px;\">IMMZD2DTJELiveRecombinantVaccineLogic</td>\n        </tr>\n        \n\n        \n        \n        <tr>\n            <th scope=\"row\"><b>Id: </b></th>\n            <td style=\"padding-left: 4px;\">IMMZD2DTJELiveRecombinantVaccineLogic</td>\n        </tr>\n        \n\n        \n        \n        <tr>\n            <th scope=\"row\"><b>Version: </b></th>\n            <td style=\"padding-left: 4px;\">1.0.0</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Url: </b></th>\n            <td style=\"padding-left: 4px;\"><a href=\"Library-IMMZD2DTJELiveRecombinantVaccineLogic.html\">IMMZD2DTJELiveRecombinantVaccineLogic</a></td>\n        </tr>\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Status: </b></th>\n            <td style=\"padding-left: 4px;\">draft</td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Type: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                    \n                        \n                        <p style=\"margin-bottom: 5px;\">\n                            <b>system: </b> <span><a href=\"http://terminology.hl7.org/7.1.0/CodeSystem-library-type.html\">http://terminology.hl7.org/CodeSystem/library-type</a></span>\n                        </p>\n                        \n                        \n                        <p style=\"margin-bottom: 5px;\">\n                            <b>code: </b> <span>logic-library</span>\n                        </p>\n                        \n                        \n                    \n                \n                \n            </td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Date: </b></th>\n            <td style=\"padding-left: 4px;\">2026-04-09 13:50:16+0000</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Publisher: </b></th>\n            <td style=\"padding-left: 4px;\">WHO</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Description: </b></th>\n            <td style=\"padding-left: 4px;\"><div><p>This library defines decision support logic for the IMMZ.D2.DT.JE.Live recombinant vaccine decision table in the Immunization CPG</p>\n</div></td>\n        </tr>\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Related Artifacts: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                \n                \n                <p><b>Dependencies</b></p>\n                <ul>\n                  \n                    <li><a href=\"Library-IMMZD2DTJEEncounterElements.html\">IMMZD2DTJEEncounterElements</a></li>\n                  \n                </ul>\n                \n                \n                \n                \n                \n            </td>\n        </tr>\n        \n\n        \n        <tr>\n          <th scope=\"row\"><b>Parameters: </b></th>\n          <td style=\"padding-left: 4px;\">\n            <table class=\"grid-dict\">\n              <tr><th><b>Name</b></th><th><b>Type</b></th><th><b>Min</b></th><th><b>Max</b></th><th><b>In/Out</b></th></tr>\n              \n                <tr><th>Today</th><th>date</th><th>0</th><th>1</th><th>In</th></tr>\n              \n                <tr><th>Patient</th><th>Patient</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Client is not due for JE vaccination Case 1</th><th>boolean</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Client is not due for JE vaccination Case 2</th><th>boolean</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Client is not due for JE vaccination</th><th>boolean</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Client is not due for JE vaccination Guidance</th><th>string</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Client is due for JE vaccination</th><th>boolean</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Client is due for JE vaccination Guidance</th><th>string</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>JE immunization schedule is complete</th><th>boolean</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>JE immunization schedule is complete Guidance</th><th>string</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Guidance</th><th>string</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Has Guidance</th><th>boolean</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n                <tr><th>Test Validation</th><th>Resource</th><th>0</th><th>1</th><th>Out</th></tr>\n              \n            </table>\n          </td>\n        </tr>\n        \n\n        \n\n        \n        \n        <tr>\n          <td colspan=\"2\">\n            <table>\n              <tr><th><a id=\"cql-content\"><b>Content: </b></a> text/cql</th></tr>\n              <tr><td><pre><code class=\"language-cql\">/*\n * Library: IMMZD2DTJELiveRecombinantVaccineLogic (IMMZ.D2.DT.JE.Live recombinant vaccine)\n * Rule: Determine if the client is due for a Japanese encephalitis (JE) vaccination according to the national immunization schedule\n * Decision Table: Live recombinant vaccination schedule (1-dose scheme)\nJE vaccination should be integrated into national immunization schedules in all areas where JE is recognized as a public health priority\n * Trigger: IMMZ.D2 Determine required vaccination(s) if any\n */\nlibrary IMMZD2DTJELiveRecombinantVaccineLogic\n\nusing FHIR version '4.0.1'\ninclude FHIRHelpers version '4.0.1'\n\ninclude IMMZD2DTJEEncounterElements called Encounter\n\nparameter Today Date default Today()\n\ncontext Patient\n\n\n/*\n@dynamicValue: Guidance\n*/\ndefine \"Guidance\":\n  case \n    when \"Client is not due for JE vaccination\" then \"Client is not due for JE vaccination Guidance\"\n    when \"Client is due for JE vaccination\" then \"Client is due for JE vaccination Guidance\"\n    when \"JE immunization schedule is complete\" then \"JE immunization schedule is complete Guidance\" \n    else ''\n  end\n  \ndefine \"Has Guidance\":\n  \"Guidance\" is not null and \"Guidance\" != ''\n\n/*\n@output: Client is not due for JE vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for JE vaccination Case 1\":\n  Encounter.\"Client's age is less than 9 months\"\n\n/*\n@output: Client is not due for JE vaccination Case 2\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for JE vaccination Case 2\":\n  Encounter.\"No JE primary series doses were administered\"\n    and Encounter.\"Client's age is more than or equal to 9 months\"\n    and Encounter.\"Live vaccine was administered in the last 4 weeks\"\n\n/*\n@output: Client is not due for JE vaccination\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for JE vaccination\":\n  \"Client is not due for JE vaccination Case 1\"\n    or \"Client is not due for JE vaccination Case 2\"\n\n/*\n@output: Client is not due for JE vaccination Guidance\n@guidance = Should not vaccinate client with JE dose as client's age is less than 9 months. \nCheck for any vaccines due and inform the caregiver of when to come back for the first JE dose.\n@guidance = Should not vaccinate client with JE dose as live vaccine was administered in the last 4 weeks. \nCheck for any other vaccines due and inform the caregiver of when to come back for the first JE dose.\n*/\ndefine \"Client is not due for JE vaccination Guidance\":\n  case\n    when \"Client is not due for JE vaccination Case 1\" then 'Should not vaccinate client with JE dose as client\\'s age is less than 9 months. \nCheck for any vaccines due and inform the caregiver of when to come back for the first JE dose.'\n    when \"Client is not due for JE vaccination Case 2\" then 'Should not vaccinate client with JE dose as live vaccine was administered in the last 4 weeks. \nCheck for any other vaccines due and inform the caregiver of when to come back for the first JE dose.'\n    else ''\n  end\n\n/*\n@output: Client is due for JE vaccination\n@pseudocode: \"Immunization recommendation status\" = \"Due\"\n*/\ndefine \"Client is due for JE vaccination\":\n  Encounter.\"No JE primary series doses were administered\"\n    and Encounter.\"Client's age is more than or equal to 9 months\"\n    and Encounter.\"No live vaccine was administered in the last 4 weeks\"\n\n/*\n@output: Client is due for JE vaccination Guidance\n@guidance: Should vaccinate client with JE dose as no JE dose was administered, client is within the appropriate age range and no live vaccine was administered in past 4 weeks. \nCheck for contraindications.\n*/\ndefine \"Client is due for JE vaccination Guidance\":\n  'Should vaccinate client with JE dose as no JE dose was administered, client is within the appropriate age range and no live vaccine was administered in past 4 weeks. \nCheck for contraindications.'\n\n/*\n@output: JE immunization schedule is complete\n@pseudocode: \"Immunization recommendation status\" = \"Complete\"\n\"Completed the primary vaccination series\" = TRUE (where \"Vaccine type\" = \"JE vaccines\")\n*/\ndefine \"JE immunization schedule is complete\":\n  Encounter.\"One JE primary series doses were administered\"\n\n/*\n@output: JE immunization schedule is complete Guidance\n@guidance: JE immunization schedule is complete. One JE primary series dose was administered. \nCheck for any other vaccines due.\n*/\ndefine \"JE immunization schedule is complete Guidance\":\n  'JE immunization schedule is complete. One JE primary series dose was administered. \nCheck for any other vaccines due.'\n\n\n/*\n@test: Test expected results based on example patients\n*/\ndefine \"Test Validation\":\n  case\n    when Patient.id = 'JE31.1' then \"Client is not due for JE vaccination Case 1\" and \"Guidance\" = 'Should not vaccinate client with JE dose as client\\'s age is less than 9 months. \nCheck for any vaccines due and inform the caregiver of when to come back for the first JE dose.'\n    when Patient.id = 'JE32.3' then \"Client is due for JE vaccination\" and \"Guidance\" = 'Should vaccinate client with JE dose as no JE dose was administered, client is within the appropriate age range and no live vaccine was administered in past 4 weeks. \nCheck for contraindications.'\n    when Patient.id = 'JE33.3' then \"Client is not due for JE vaccination Case 2\" and \"Guidance\" = 'Should not vaccinate client with JE dose as live vaccine was administered in the last 4 weeks. \nCheck for any other vaccines due and inform the caregiver of when to come back for the first JE dose.'\n    when Patient.id = 'JE34.1' then \"JE immunization schedule is complete\" and \"Guidance\" = 'JE immunization schedule is complete. One JE primary series dose was administered. \nCheck for any other vaccines due.'\n    else 'No test case set'\n  end\n</code></pre></td></tr>\n            </table>\n          </td>\n        </tr>\n        \n        \n        \n    </table>\n</div>\n</div>"^^rdf:XMLLiteral ]
  ] ; # 
