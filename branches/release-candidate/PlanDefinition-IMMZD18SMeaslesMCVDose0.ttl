         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: MCV0 Due Date\n@pseudocode: \"Date of birth\" + 6 months\n*/\ndefine \"MCV0 Due Date\":\n  if \"MCV0\" then Patient.birthDate + 6 months\n  else null"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
