           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: Tetanus and diphtheria-containing vaccine booster dose 3 Due Date\n@pseudocode: Latest \"Date and time of vaccination\" (where \"Vaccine type\" = \"Tetanus and diphtheria-containing vaccines\") + 1 year or during next pregnancy\n*/\ndefine \"Tetanus and diphtheria-containing vaccine booster dose 3 Due Date\":\n  if \"Tetanus and diphtheria-containing vaccine booster dose 3\" then Encounter.\"Date of Latest Td Dose\" + 1 year\n  else null"
         ]
       ] [
