           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Tetanus and diphtheria-containing vaccine booster dose 3 Create"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Tetanus and diphtheria-containing vaccine booster dose 3 Create\n@create: To provide lifelong protection for tetanus, a sixth dose should be provided at least 1 year after the fifth dose, or in next pregnancy.\n*/\ndefine \"Tetanus and diphtheria-containing vaccine booster dose 3 Create\":\n  if \"Tetanus and diphtheria-containing vaccine booster dose 3\"\n  then 'To provide lifelong protection for tetanus, a sixth dose should be provided at least 1 year after the fifth dose, or in next pregnancy.' + '\nDue Date: ' + ToString(\"Tetanus and diphtheria-containing vaccine booster dose 3 Due Date\")\n  else ''"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
