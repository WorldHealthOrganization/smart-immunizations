           fhir:v "First hepatitis B dose from the primary series was administered"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@complete: First hepatitis B dose from the primary series was administered\n@pseudocode: Count of vaccines administered (where \"Vaccine type\" = \"Hepatitis B-containing vaccines\" and \"Type of dose\"= \"Primary series\") = 1\n*/\ndefine \"First hepatitis B dose from the primary series was administered\":\n  Encounter.\"One hepatitis B primary series dose was administered\""
