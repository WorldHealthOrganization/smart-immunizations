         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Third TBE dose from the primary series was administered. The primary series has been completed"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
