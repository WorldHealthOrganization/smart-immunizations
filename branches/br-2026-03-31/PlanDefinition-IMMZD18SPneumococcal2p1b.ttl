           fhir:v "http://smart.who.int/immunizations/CodeSystem/IMMZ.D"^^xsd:anyURI ;
           fhir:l <http://smart.who.int/immunizations/CodeSystem/IMMZ.D>
         ] ;
         fhir:code [ fhir:v "DE208" ] ;
