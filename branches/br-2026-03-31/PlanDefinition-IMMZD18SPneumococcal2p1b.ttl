         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@internal: Pneumococcal containing Doses Administered to Patient that are in the Primary series\n*/\ndefine \"Pneumococcal Primary Series Doses Administered to Patient\":\n  \"Pneumococcal Doses Administered to Patient\".seriesPrimary()"
         ]
       ] [
         fhir:url [
