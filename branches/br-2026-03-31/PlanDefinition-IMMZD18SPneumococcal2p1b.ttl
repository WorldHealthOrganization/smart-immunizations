         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@internal: Number of Pneumococcal Primary Series doses\n*/\ndefine \"Number of Pneumococcal Primary Series Doses Administered\":\n  Count(\"Pneumococcal Primary Series Doses Administered to Patient\")"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
