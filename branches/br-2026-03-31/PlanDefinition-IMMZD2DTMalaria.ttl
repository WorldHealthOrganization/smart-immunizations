  fhir:description [ fhir:v "IMMZ.D2.DT.Malaria\n4-dose schedule (The RTS,S/AS01 malaria vaccine should be used for the prevention of Plasmodium falciparum malaria in children living in regions with moderate to high malaria transmission, as defined by WHO)"] ; # 
