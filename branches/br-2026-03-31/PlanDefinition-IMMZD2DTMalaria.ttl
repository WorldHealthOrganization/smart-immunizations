         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "The vaccine should be administered in a 3-dose primary schedule, with a fourth dose \nprovided approximately 12–18 months after the third dose to prolong the duration of protection. \nThere should be a minimum interval of 4 weeks between doses."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determine if the client is due for Malaria." ] ;
     fhir:description [ fhir:v "Determine if the client is due for Malaria vaccine according to the national immunization protocol.\n4-dose schedule (The RTS,S/AS01 malaria vaccine should be used for the prevention of Plasmodium \nfalciparum malaria in children living in regions with moderate to high malaria transmission, as \ndefined by WHO)" ] ;
