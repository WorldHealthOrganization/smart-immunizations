  fhir:description [ fhir:v "IMMZ.D2.DT.Varicella.1 dose\nCountries where varicella is an important public health burden could consider introducing varicella vaccination in the routine childhood immunization programme. However, resources should be sufficient to ensure reaching and sustaining vaccine coverage ≥ 80%. Decision-making on childhood varicella vaccination should also include consideration of the possible impact on herpes zoster.\nThe number of doses recommended is dependent on the goal of the vaccination programme. One dose is sufficient to reduce mortality and severe morbidity from varicella but not to prevent limited virus circulation and outbreaks. Two doses have higher effectiveness and should therefore be recommended in countries where the programmatic goal is, in addition to decreasing mortality and severe morbidity, to further reduce the number of cases and outbreaks."] ; # 
  fhir:relatedArtifact ( [
     fhir:type [ fhir:v "citation" ] ;
     fhir:citation [ fhir:v "WHO recommendations for routine immunization - summary tables (January 2025)" ]
  ] ) ; # 
  fhir:library ( [
     fhir:v "http://smart.who.int/immunizations/Library/IMMZD2DTVaricella1DoseLogic"^^xsd:anyURI ;
     fhir:l <http://smart.who.int/immunizations/Library/IMMZD2DTVaricella1DoseLogic>
  ] ) ; # 
  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "Countries where varicella is an important public health burden could consider introducing \nvaricella vaccination in the routine childhood immunization programme. However, resources should be \nsufficient to ensure reaching and sustaining vaccine coverage ≥ 80%. Decision-making on childhood \nvaricella vaccination should also include consideration of the possible impact on herpes zoster. \nThe number of doses recommended is dependent on the goal of the vaccination programme. One dose \nis sufficient to reduce mortality and severe morbidity from varicella but not to prevent limited \nvirus circulation and outbreaks. Two doses have higher effectiveness and should therefore be \nrecommended in countries where the programmatic goal is, in addition to decreasing mortality \nand severe morbidity, to further reduce the number of cases and outbreaks.\nDepending on the goal of the vaccination programme, 1–2 doses should be given with the first dose \nadministered at 12–18 months of age.\nVaricella-containing vaccine can be administered concomitantly with other vaccines included in the \nroutine childhood immunization programme. Unless given together with other live viral vaccines \n(measles, MR [measles and rubella], MMR [measles, mumps and rubella]), it should be administered \nat a minimum interval of 28 days."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determine if the client is due for Varicella." ] ;
     fhir:description [ fhir:v "Determine if the client is due for Varicella vaccine according to the national immunization protocol.\n1-dose schedule" ] ;
