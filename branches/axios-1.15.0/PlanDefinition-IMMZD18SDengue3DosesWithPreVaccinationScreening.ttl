         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@internal: Dengue containing Doses Administered to Patient\n*/\ndefine \"Dengue Doses Administered to Patient\":\n  Encounter.\"Doses Administered to Patient\" I\n  where\n    I.vaccineCode in Concepts.\"Dengue vaccines\""
