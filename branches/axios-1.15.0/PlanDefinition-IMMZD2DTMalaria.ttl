         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "define \"Has Guidance\":\n  \"Guidance\" is not null and \"Guidance\" != ''"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
