         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@input: One Hib primary series dose was administered\n@pseudocode: Count of vaccines administered (where \"Vaccine type\" = \"Hib-containing vaccines\" and \"Type of dose\"= \"Primary series\") = 1\n@code: One Hib primary series dose was administered-122\n@decision: IMMZ.D2.DT.Hib.3 doses: 3 primary doses without a booster dose (3p)\n@decision: IMMZ.D2.DT.Hib.3 doses with booster dose: 3 primary doses with a booster dose (3p+1)\n*/\ndefine \"One Hib primary series dose was administered\":\n  \"Number of Hib Primary Series Doses Administered\" = 1"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
