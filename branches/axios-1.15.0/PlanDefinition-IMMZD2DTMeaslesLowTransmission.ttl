         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is not due for MCV2\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for MCV2\":\n  \"Client is not due for MCV2 Case 1\"\n    or \"Client is not due for MCV2 Case 2\""
