           fhir:v "/*\n@output: Client is not due for MCV1 Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for MCV1 Case 1\":\n  Encounter.\"Client's age is less than 12 months\""
