         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is not due for MCV2 Case 2\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for MCV2 Case 2\":\n  Encounter.\"MCV1 was administered\"\n    and Encounter.\"Client's age is more than or equal to 15 months\"\n    and Encounter.\"Live vaccine was administered in the last 4 weeks\""
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
