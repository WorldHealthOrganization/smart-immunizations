         fhir:expression [ fhir:v "Concept { codes: { Code { system: 'http://smart.who.int/immunizations/CodeSystem/IMMZ.Z', code: 'DE9', display: 'Measles-containing vaccines' } }, display: 'Measles-containing vaccines' }" ]
       ]
     ] )
  ] [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "In countries with low levels of measles transmission, administration of MCV2 at 15-18 months of age ensures early \nprotection of the individual. The minimum interval between MCV1 and MCV2 is 4 weeks. As a general rule, live vaccines should \nbe given either simultaneously or at intervals of 4 weeks. An exception to this rule is OPV, which can be given at any time \nbefore or after measles vaccination without interference in the response to either vaccine."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determine if the client is due for MCV2 in countries with low transmission." ] ;
     fhir:description [ fhir:v "Determine if the client is due for measles vaccination MCV2 according to the national immunization protocol.\nCountries with low levels of measles transmission." ] ;
     fhir:condition ( [
       fhir:kind [ fhir:v "applicability" ] ;
       fhir:expression [
         fhir:description [ fhir:v "Client is due for MCV2" ] ;
         fhir:language [ fhir:v "text/cql-identifier" ] ;
         fhir:expression [ fhir:v "Client is due for MCV2" ]
       ]
