  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZ.Z.VS</b></p><a name=\"IMMZ.Z.VS\"> </a><a name=\"hcIMMZ.Z.VS\"> </a><p>This value set includes codes based on the following rules:</p><ul><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE1.html\">IMMZ.Z.DE1 ValueSet for BCG vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE2.html\">IMMZ.Z.DE2 ValueSet for Cholera vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE3.html\">IMMZ.Z.DE3 ValueSet for Diphtheria-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE4.html\">IMMZ.Z.DE4 ValueSet for Hib-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE5.html\">IMMZ.Z.DE5 ValueSet for Hepatitis A-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE6.html\">IMMZ.Z.DE6 ValueSet for Hepatitis B-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE7.html\">IMMZ.Z.DE7 ValueSet for HPV vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE8.html\">IMMZ.Z.DE8 ValueSet for JE vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE9.html\">IMMZ.Z.DE9 ValueSet for Measles-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE10.html\">IMMZ.Z.DE10 ValueSet for Meningococcal vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE11.html\">IMMZ.Z.DE11 ValueSet for Mumps-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE12.html\">IMMZ.Z.DE12 ValueSet for Pertussis-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE13.html\">IMMZ.Z.DE13 ValueSet for Pneumococcal vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE14.html\">IMMZ.Z.DE14 ValueSet for Poliovirus-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE15.html\">IMMZ.Z.DE15 ValueSet for Rabies vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE16.html\">IMMZ.Z.DE16 ValueSet for Rotavirus vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE17.html\">IMMZ.Z.DE17 ValueSet for Rubella-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE18.html\">IMMZ.Z.DE18 ValueSet for Seasonal influenza vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE19.html\">IMMZ.Z.DE19 ValueSet for Tetanus-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE20.html\">IMMZ.Z.DE20 ValueSet for TBE vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE21.html\">IMMZ.Z.DE21 ValueSet for Typhoid vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE22.html\">IMMZ.Z.DE22 ValueSet for Varicella-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE23.html\">IMMZ.Z.DE23 ValueSet for Yellow fever vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE24.html\">IMMZ.Z.DE24 ValueSet for DTP-containing vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE25.html\">IMMZ.Z.DE25 ValueSet for Dengue vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE26.html\">IMMZ.Z.DE26 ValueSet for COVID-19 vaccines</a></li><li>Import all the codes that are contained in <a href=\"ValueSet-IMMZ.Z.DE27.html\">