  fhir:PlanDefinition.description [ fhir:value "IMMZ.D2.DT.Mumps\n2-dose schedule (countries with mumps in schedule and low transmission of measles)"] ;
  fhir:PlanDefinition.relatedArtifact [
     fhir:index 0 ;
     fhir:RelatedArtifact.type [ fhir:value "citation" ] ;
     fhir:RelatedArtifact.citation [ fhir:value "WHO recommendations for routine immunization - summary tables (January 2025)" ]
  ] ;
  fhir:PlanDefinition.library [
     fhir:value "http://smart.who.int/immunizations/Library/IMMZD2DTMumpsLogic" ;
     fhir:index 0 ;
     fhir:link <http://smart.who.int/immunizations/Library/IMMZD2DTMumpsLogic>
