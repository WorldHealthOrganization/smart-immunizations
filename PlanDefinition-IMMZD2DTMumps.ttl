         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is due for mumps vaccination\n@pseudocode: \"Immunization recommendation status\" = \"Due\"\n*/\ndefine \"Client is due for mumps vaccination\":\n  \"Client is due for mumps vaccination Case 1\"\n    or \"Client is due for mumps vaccination Case 2\""
         ]
       ] [
