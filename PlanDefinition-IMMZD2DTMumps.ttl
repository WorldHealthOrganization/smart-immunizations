         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Mumps immunization schedule is complete\n@pseudocode: \"Immunization recommendation status\" = \"Complete\"\n\"Completed the primary vaccination series\" = TRUE (where \"Vaccine type\" = \"Mumps-containing vaccines\")\"\n*/\ndefine \"Mumps immunization schedule is complete\":\n  Encounter.\"Two mumps primary series doses were administered\""
         ]
       ] [
         fhir:url [
