  fhir:action ( [
     fhir:extension ( [
       fhir:url [
         fhir:v "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale>
       ] ;
       fhir:value [
         a fhir:Markdown ;
         fhir:v "The first dose of the mumps-containing vaccine (monovalent or MMR [measles, mumps and rubella]) \nshould be given at the age of 12–18 months. As a general rule, live vaccines should be given either simultaneously \nor at intervals of 4 weeks.\nThe age of administration of the second dose may range from the second year of life to age at school entry. \nThe minimum interval between the first and the second doses is 1 month. As a general rule, live vaccines \nshould be given either simultaneously or at intervals of 4 weeks."
       ]
     ] ) ;
     fhir:title [ fhir:v "Determine if the client is due for Mumps." ] ;
     fhir:description [ fhir:v "Determine if the client is due for Mumps vaccine according to the national immunization protocol.\n2-dose schedule (countries with mumps in schedule and low transmission of measles)" ] ;
