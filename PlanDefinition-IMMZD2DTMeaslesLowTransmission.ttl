  fhir:PlanDefinition.action [
     fhir:index 0 ;
     fhir:Element.extension [
       fhir:index 0 ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale" ] ;
       fhir:Extension.valueMarkdown [ fhir:value "In countries with low levels of measles transmission MCV1 may be administered at 12 months of age. As a general rule, \n  live vaccines should be given either simultaneously or at intervals of 4 weeks. An exception to this rule is OPV, which can be \n  given at any time before or after measles vaccination without interference in the response to either vaccine." ]
     ] ;
     fhir:PlanDefinition.action.title [ fhir:value "Determine if the client is due for MCV1 in countries with low transmission." ] ;
