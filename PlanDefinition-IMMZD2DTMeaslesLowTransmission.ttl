  fhir:PlanDefinition.description [ fhir:value "IMMZ.D2.DT.Measles.Low transmission\nCountries with low levels of measles transmission (countries that provide first dose of measles-containing vaccine (MCV) at 12 months and second dose of MCV at 15 months)"] ;
