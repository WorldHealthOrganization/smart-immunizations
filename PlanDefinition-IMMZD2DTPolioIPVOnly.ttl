  fhir:PlanDefinition.description [ fhir:value "IMMZ.D2.DT.Polio.IPV-only\nInactivated polio vaccine (IPV)-only (in countries, in polio-free regions, with a very low risk of importation and sustained high routine immunization coverage (third dose of the diphtheria–tetanus–pertussis vaccine [DTP3] > 90%)"] ;
  fhir:PlanDefinition.relatedArtifact [
     fhir:index 0 ;
     fhir:RelatedArtifact.type [ fhir:value "citation" ] ;
