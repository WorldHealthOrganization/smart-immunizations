         fhir:Extension.valueString [ fhir:value "WHOCommon" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "mostRecent" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "define fluent function mostRecent(immunizations List<Immunization>):\n  Last(\n    immunizations I\n      sort by start of occurrence.toInterval()\n  )" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "87"^^xsd:integer ]
