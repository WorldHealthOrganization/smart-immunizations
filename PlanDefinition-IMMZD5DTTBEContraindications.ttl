         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: Guidance\n*/\ndefine \"Guidance\":\n  case \n    when \"Clinical judgement is required. Create a clinical note\" then \"Clinical judgement is required. Create a clinical note Guidance\" \n    else ''\n  end" ]
