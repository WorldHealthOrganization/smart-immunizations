       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for HPV vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for HPV vaccination Case 1\":\n  Encounter.\"Client's age is less than 9 years\"" ]
       ], [
         fhir:index 3 ;
