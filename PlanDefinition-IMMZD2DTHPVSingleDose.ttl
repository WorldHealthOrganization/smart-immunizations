         fhir:Extension.valueString [ fhir:value "/*\n@internal: Number of HPV Primary Series doses\n*/\ndefine \"Number of HPV Primary Series Doses Administered\":\n  Count(\"HPV Primary Series Doses Administered to Patient\")" ]
