         fhir:Extension.valueString [ fhir:value "Cholera dose 2 Expiration" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: Cholera dose 2 Expiration\n@pseudocode: Latest \"Date and time of vaccination\" (where \"Vaccine type\" = \"Cholera vaccines\") + 6 weeks\n*/\ndefine \"Cholera dose 2 Expiration\":\n  Encounter.\"Date of Latest Cholera Dose\" + 6 weeks" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "9"^^xsd:integer ]
       ] ;
