  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZD5DTBCGContraindicationsVS</b></p><a name=\"IMMZD5DTBCGContraindicationsVS\"> </a><a name=\"hcIMMZD5DTBCGContraindicationsVS\"> </a><p>This value set expansion contains 9 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20is|20pregnant-52\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclientispregnant-52\">The client is pregnant-52</a></td><td>The client is pregnant</td><td><div><p>\"Potential contraindications\" = \"Currently pregnant\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Bacille|20Calmette|2013Gu|e9rin|20(BCG)|20vaccination|20is|20contraindicated-57\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-BacilleCalmette.8211Gu.233rin.40BCG.41vaccinationiscontraindicated-57\">Bacille Calmette–Guérin (BCG) vaccination is contraindicated-57</a></td><td>Bacille Calmette–Guérin (BCG) vaccination is contraindicated</td><td><div><p>'\"Immunization recommendation status\" = \"Contraindicated\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20has|20history|20of|20severe|20allergic|20reactions-60\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclienthashistoryofsevereallergicreactions-60\">The client has history of severe allergic reactions-60</a></td><td>The client has history of severe allergic reactions</td><td><div><p>'\"Potential contraindications\" = \"Severe allergic reactions\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-BCG|20vaccination|20could|20be|20contraindicated.|20Clinical|20judgement|20is|20required.|20Create|20a|20clinical|20note.-67\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-BCGvaccinationcouldbecontraindicated.46Clinicaljudgementisrequired.46Createaclinicalnote.46-67\">BCG vaccination could be contraindicated. Clinical judgement is required. Create a clinical note.-67</a></td><td>BCG vaccination could be contraindicated. Clinical judgement is required. Create a clinical note.</td><td><div><p>'\"Immunization recommendation status\" = \"Further evaluation needed\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20has|20immunodeficiency|20syndromes-60\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclienthasimmunodeficiencysyndromes-60\">The client has immunodeficiency syndromes-60</a></td><td>The client has immunodeficiency syndromes</td><td><div><p>\"Potential contraindications\" = \"Immunodeficiency syndromes\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-BCG|20vaccination|20is|20contraindicated-57\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-BCGvaccinationiscontraindicated-57\">BCG vaccination is contraindicated-57</a></td><td>BCG vaccination is contraindicated</td><td><div><p>'\"Immunization recommendation status\" = \"Contraindicated\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-The|20client|20is|20exposed|20to|20immunosuppressive|20treatment-72\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Theclientisexposedtoimmunosuppressivetreatment-72\">The client is exposed to immunosuppressive treatment-72</a></td><td>The client is exposed to immunosuppressive treatment</td><td><div><p>\"Potential contraindications\" = \"Exposed to immunosuppressive treatment\"</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client's|20age|20is|20less|20than|201|20year-14\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Client.39sageislessthan1year-14\">Client's age is less than 1 year-14</a></td><td>Client's age is less than 1 year</td><td><div><p>\"Age\" &lt; 1 year</p>\n</div></td></tr><tr><td><a name=\"IMMZD5DTBCGContraindicationsVS-http://smart.who.int/immunizations/CodeSystem/IMMZDAK-Client's|20age|20is|20more|20than|20or|20equal|20to|201|20year-14\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZDAK</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZDAK.html#IMMZDAK-Client.39sageismorethanorequalto1year-14\">Client's age is more than or equal to 1 year-14</a></td><td>Client's age is more than or equal to 1 year</td><td><div><p>\"Age\" ≥ 1 year</p>\n</div></td></tr></table></div>"
