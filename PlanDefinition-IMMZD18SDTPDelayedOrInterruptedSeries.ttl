         fhir:value [
           a fhir:String ;
           fhir:v "Three DTP primary series doses were administered"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
