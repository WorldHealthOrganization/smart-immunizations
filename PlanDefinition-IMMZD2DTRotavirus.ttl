  fhir:PlanDefinition.action [
     fhir:index 0 ;
     fhir:Element.extension [
       fhir:index 0 ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale" ] ;
       fhir:Extension.valueMarkdown [ fhir:value "WHO recommends that the first dose of rotavirus vaccine be administered as soon as possible after 6 weeks of age.\n  A minimum interval of 4 weeks should be maintained between doses.  Note: The rotavirus vaccination series for each child should \n  be completed with the same product whenever feasible. However, if the product used for a prior dose is unavailable or unknown, \n  the series should be completed with any available licensed product." ]
     ] ;
     fhir:PlanDefinition.action.title [ fhir:value "Determine if the client is due for Rotavirus." ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Determine if the client is due for Rotavirus vaccine according to the national immunization protocol." ] ;
     fhir:PlanDefinition.action.condition [
       fhir:index 0 ;
       fhir:PlanDefinition.action.condition.kind [ fhir:value "applicability" ] ;
       fhir:PlanDefinition.action.condition.expression [
         fhir:Expression.description [ fhir:value "Client is due for rotavirus vaccination" ] ;
         fhir:Expression.language [ fhir:value "text/cql-identifier" ] ;
         fhir:Expression.expression [ fhir:value "Client is due for rotavirus vaccination" ]
       ]
     ] ;
     fhir:PlanDefinition.action.definitionCanonical [
       fhir:value "http://smart.who.int/immunizations/ActivityDefinition/IMMZD2DTMR" ;
       fhir:link <http://smart.who.int/immunizations/ActivityDefinition/IMMZD2DTMR>
     ] ;
     fhir:PlanDefinition.action.dynamicValue [
       fhir:index 0 ;
