         fhir:Extension.valueString [ fhir:value "Client's age is between 6 weeks and 24 months" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@input: Client's age is between 6 weeks and 24 months\n@pseudocode: 6 weeks ≤ Today's date – \"Date of birth\" < 24 months\n@code: Client's age is between 6 weeks and 24 months-52\n@decision: IMMZ.D2.DT.Rotavirus\n*/\ndefine \"Client's age is between 6 weeks and 24 months\":\n  6 <= Encounter.\"Current Patient Age In Weeks\"\n  and Encounter.\"Current Patient Age In Months\" < 24" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "10"^^xsd:integer ]
       ] ;
