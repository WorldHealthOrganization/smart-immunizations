       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@input: Client's age is less than 6 weeks\n@pseudocode: 'Today's date – \"Date of birth\" < 6 weeks\n@code: Client's age is less than 6 weeks-41\n@decision: IMMZ.D2.DT.Rotavirus\n*/\ndefine \"Client's age is less than 6 weeks\":\n  Encounter.\"Current Patient Age In Weeks\" < 6" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "1"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 2 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTRotavirusLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is not due for rotavirus vaccination Case 1" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for rotavirus vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for rotavirus vaccination Case 1\":\n  Encounter.\"Client's age is less than 6 weeks\"" ]
       ], [
