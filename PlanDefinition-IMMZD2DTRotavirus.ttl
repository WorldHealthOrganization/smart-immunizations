       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/**\n * @description: Gets the series doses from an immunization\n */\ndefine fluent function seriesDoses(immunization Immunization):\n  First(immunization.protocolApplied pa where pa.seriesDoses is not null).seriesDoses" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "61"^^xsd:integer ]
