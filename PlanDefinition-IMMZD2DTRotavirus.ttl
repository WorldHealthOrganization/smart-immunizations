         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTRotavirusEncounterElements" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Rotavirus Doses Administered to Patient" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@internal: Rotavirus containing Doses Administered to Patient\n*/\ndefine \"Rotavirus Doses Administered to Patient\":\n  Encounter.\"Doses Administered to Patient\" I\n  where\n    I.vaccineCode in Concepts.\"Rotavirus vaccines\"" ]
