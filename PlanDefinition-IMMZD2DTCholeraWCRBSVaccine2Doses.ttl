         fhir:Extension.valueString [ fhir:value "IMMZD2DTCholeraWCRBSVaccine2DosesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Primary series is complete. Client is due for cholera booster dose Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Primary series is complete. Client is due for cholera booster dose Guidance\n@guidance: Should vaccinate client with cholera booster dose as the latest cholera dose was administered approximately less than 2 years ago. \nCheck for contraindications.\n*/\ndefine \"Primary series is complete. Client is due for cholera booster dose Guidance\":\n  'Should vaccinate client with cholera booster dose as the latest cholera dose was administered approximately less than 2 years ago. \nCheck for contraindications.'" ]
       ], [
