  fhir:PlanDefinition.description [ fhir:value "IMMZ.D2.DT.Cholera.WC-rBS vaccine 2 doses\nWhole cell-recombinant B subunit (WC-rBS) vaccine, 2-dose schedule for clients aged over 5 years"] ;
  fhir:PlanDefinition.relatedArtifact [
