       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is due for cholera vaccination\n@pseudocode: \"Immunization recommendation status\" = \"Due\"\n*/\ndefine \"Client is due for cholera vaccination\":\n  \"Client is due for cholera vaccination Case 1\"\n    or \"Client is due for cholera vaccination Case 2\"\n    or \"Client is due for cholera vaccination Case 3\"\n    or \"Client is due for cholera vaccination Case 4\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "19"^^xsd:integer ]
       ] ;
