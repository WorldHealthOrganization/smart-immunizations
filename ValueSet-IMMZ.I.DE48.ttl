  fhir:DomainResource.text [
     fhir:Narrative.status [ fhir:value "generated" ] ;
     fhir:Narrative.div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: ValueSet IMMZ.I.DE48</b></p><a name=\"IMMZ.I.DE48\"> </a><a name=\"hcIMMZ.I.DE48\"> </a><p>This value set expansion contains 5 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"IMMZ.I.DE48-http://smart.who.int/immunizations/CodeSystem/IMMZ.I-DE49\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.I</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.I.html#IMMZ.I-DE49\">DE49</a></td><td>Broken/damaged</td><td>The vaccine is physically damaged or broken, rendering it unsuitable for use</td></tr><tr><td><a name=\"IMMZ.I.DE48-http://smart.who.int/immunizations/CodeSystem/IMMZ.I-DE50\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.I</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.I.html#IMMZ.I-DE50\">DE50</a></td><td>Expired product</td><td>The vaccine has reached its expiration date and is no longer safe or effective for use</td></tr><tr><td><a name=\"IMMZ.I.DE48-http://smart.who.int/immunizations/CodeSystem/IMMZ.I-DE51\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.I</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.I.html#IMMZ.I-DE51\">DE51</a></td><td>Cold storage malfunction</td><td>There has been a malfunction or failure in the cold storage equipment, which has led to the degradation of the vaccine</td></tr><tr><td><a name=\"IMMZ.I.DE48-http://smart.who.int/immunizations/CodeSystem/IMMZ.I-DE52\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.I</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.I.html#IMMZ.I-DE52\">DE52</a></td><td>Vaccine vial monitor status change</td><td>The vaccine vial monitor has indicated a change in status, possibly indicating that the vaccines may no longer be viable</td></tr><tr><td><a name=\"IMMZ.I.DE48-http://smart.who.int/immunizations/CodeSystem/IMMZ.I-DE53\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.I</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.I.html#IMMZ.I-DE53\">DE53</a></td><td>Frozen</td><td>The vaccine has been exposed to freezing temperatures, making it unsuitable for use as freezing can affect the integrity and efficacy of certain immunization products</td></tr></table></div>"
  ] ;
