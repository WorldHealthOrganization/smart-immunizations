     ], [
       fhir:index 13 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTPneumococcalEncounterElements" ]
       ], [
         fhir:index 1 ;
