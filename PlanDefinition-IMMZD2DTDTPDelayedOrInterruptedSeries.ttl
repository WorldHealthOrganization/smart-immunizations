  fhir:PlanDefinition.url [ fhir:value "http://smart.who.int/immunizations/PlanDefinition/IMMZD2DTDTPDelayedOrInterruptedSeries"] ;
  fhir:PlanDefinition.version [ fhir:value "0.2.0"] ;
  fhir:PlanDefinition.name [ fhir:value "IMMZD2DTDTPDelayedOrInterruptedSeries"] ;
  fhir:PlanDefinition.title [ fhir:value "IMMZ.D2.DT.DTP.Delayed or interrupted series"] ;
  fhir:PlanDefinition.type [
     fhir:CodeableConcept.coding [
       fhir:index 0 ;
       fhir:Coding.system [ fhir:value "http://terminology.hl7.org/CodeSystem/plan-definition-type" ] ;
       fhir:Coding.code [ fhir:value "eca-rule" ]
     ]
  ] ;
  fhir:PlanDefinition.status [ fhir:value "draft"] ;
  fhir:PlanDefinition.experimental [ fhir:value "false"^^xsd:boolean] ;
  fhir:PlanDefinition.date [ fhir:value "2026-07-07T22:08:04+00:00"^^xsd:dateTime] ;
  fhir:PlanDefinition.publisher [ fhir:value "WHO"] ;
  fhir:PlanDefinition.contact [
     fhir:index 0 ;
     fhir:ContactDetail.name [ fhir:value "WHO" ] ;
     fhir:ContactDetail.telecom [
       fhir:index 0 ;
       fhir:ContactPoint.system [ fhir:value "url" ] ;
