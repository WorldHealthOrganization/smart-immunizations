         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Hepatitis A dose 2\n@description: Provision of the hepatitis A dose 2\n@trigger: First hepatitis A dose from the primary series was administered\n@pseudo: Count of vaccines administered (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\" and \"Type of dose\" = \"Primary series\") = 1\n@triggerDate: \"Date and time of vaccination\" (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\")\n*/\ndefine \"Hepatitis A dose 2\":\n  \"First hepatitis A dose from the primary series was administered\"\n  and not \"Second hepatitis A dose from the primary series was administered. The primary series has been completed\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "13"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 14 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTHepatitisAEncounterElements" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Date of Latest Hepatitis A Dose" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@internal: Date of Latest Hepatitis A Dose\n*/\ndefine \"Date of Latest Hepatitis A Dose\":\n  date from start of \"Hepatitis A Doses Administered to Patient\".mostRecent().occurrence.toInterval()" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "14"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 15 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD18SHepatitisAInactivatedHAV2DosesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Hepatitis A dose 2 Due Date" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@dynamicValue: Hepatitis A dose 2 Due Date\n@pseudocode: \"Date and time of vaccination\" (where \"Vaccine type\" = \"Hepatitis A-containing vaccines\") + 6 months\n*/\ndefine \"Hepatitis A dose 2 Due Date\":\n  if \"Hepatitis A dose 2\" then Encounter.\"Date of Latest Hepatitis A Dose\" + 6 months\n  else null" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "15"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 16 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD18SHepatitisAInactivatedHAV2DosesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Hepatitis A dose 2 Create" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Hepatitis A dose 2 Create\n@create: The interval between doses is flexible, from 6 months to 4–5 years or more, but is usually 6–18 months.\n*/\ndefine \"Hepatitis A dose 2 Create\":\n  if \"Hepatitis A dose 2\"\n  then 'The interval between doses is flexible, from 6 months to 4–5 years or more, but is usually 6–18 months.' + '\nDue Date: ' + ToString(\"Hepatitis A dose 2 Due Date\")\n  else ''" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "16"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 17 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZCommon" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "seriesPrimary" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/**\n * @description: Gets the doses from the primary series\n */\ndefine fluent function seriesPrimary(immunizations List<Immunization>):\n  immunizations I where\n    exists( I.protocolApplied pa where pa.series = 'Primary series' )" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "17"^^xsd:integer ]
