       fhir:index 0 ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale" ] ;
       fhir:Extension.valueMarkdown [ fhir:value "The EnceVir vaccine is licensed for use in people aged 3 years and older.\nThe manufacturer of EnceVir recommends 2 doses given at an interval of 5–7 months. For EnceVir, \nthere is a rapid schedule for emergency situations: an interval of 1–2 months between the first 2 doses. \nThe manufacturer of EnceVir recommends 2 doses given at an interval of 5-7 months.\nThe recommended interval is 12 months between the second and third doses." ]
     ] ;
