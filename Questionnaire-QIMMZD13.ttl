.D.html#IMMZ.D-DE255\">DE255</a></td><td>Hepatitis B monovalent vaccine</td><td>Hepatitis B monovalent vaccine</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE254-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE256\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE256\">DE256</a></td><td>Hepatitis B combination vaccine</td><td>Hepatitis B combination vaccine</td></tr></table><hr/><p class=\"res-header-id\"><b>ValueSet #IMMZ.D.DE1</b></p><a name=\"QIMMZD13/IMMZ.D.DE1\"> </a><a name=\"hcQIMMZD13/IMMZ.D.DE1\"> </a><p>This value set expansion contains 3 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE1-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE2\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE2\">DE2</a></td><td>Completed</td><td>The immunization event was successfully carried out as intended</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE1-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE3\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE3\">DE3</a></td><td>Entered in error</td><td>Immunization event record has been mistakenly created or entered into the system. Recorded information is incorrect or should not have been documented, though it is possible that real-world decisions were based on it</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE1-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE4\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE4\">DE4</a></td><td>Not done</td><td>Planned immunization event was not carried out for some reason</td></tr></table><hr/><p class=\"res-header-id\"><b>ValueSet #IMMZ.D.DE5</b></p><a name=\"QIMMZD13/IMMZ.D.DE5\"> </a><a name=\"hcQIMMZD13/IMMZ.D.DE5\"> </a><p>This value set expansion contains 12 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td><td><b>Definition</b></td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE6\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE6\">DE6</a></td><td>Immunity</td><td>Testing has shown that the client already has immunity to the agent targeted by the immunization</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE7\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE7\">DE7</a></td><td>Medical precaution</td><td>The client currently has a medical condition for which the vaccine is contraindicated or for which precaution is warranted</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE8\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE8\">DE8</a></td><td>Product out of stock</td><td>There was no supply of the product on hand to perform the service</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE9\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE9\">DE9</a></td><td>Client objection</td><td>The client or their guardian objects to receiving the vaccine</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE10\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE10\">DE10</a></td><td>Caregiver refusal</td><td>The client's caregiver refused the vaccine</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE11\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE11\">DE11</a></td><td>Unspecified reason</td><td>The immunization event was not carried out for an unspecified reason</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE12\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE12\">DE12</a></td><td>Client allergy to vaccine or component</td><td>The immunization event was not carried out because of client allergy to vaccine or component</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE13\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE13\">DE13</a></td><td>Immunocompromised</td><td>The immunization event was not carried out because the client is immunocompromised</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE14\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE14\">DE14</a></td><td>Chronic illness or condition</td><td>The immunization event was not carried out due a chronic illness or condition of the client</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE15\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE15\">DE15</a></td><td>Acute illness</td><td>The immunization event was not carried out due to an acute illness present in the client</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE16\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE16\">DE16</a></td><td>Had the disease</td><td>The immunization event was not carried out due to the client having had the disease</td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE5-http://smart.who.int/immunizations/CodeSystem/IMMZ.D-DE17\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.D</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.D.html#IMMZ.D-DE17\">DE17</a></td><td>Immunization not carried out for other reasons</td><td>The immunization event was not carried out for other reasons</td></tr></table><hr/><p class=\"res-header-id\"><b>ValueSet #IMMZ.D.DE18</b></p><a name=\"QIMMZD13/IMMZ.D.DE18\"> </a><a name=\"hcQIMMZD13/IMMZ.D.DE18\"> </a><p>This value set expansion contains 1 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"white-space:nowrap\"><b>Code</b></td><td><b>Display</b></td></tr><tr><td><a name=\"QIMMZD13/IMMZ.D.DE18-http://smart.who.int/immunizations/CodeSystem/IMMZ.Ex-brand\"> </a><code>http://smart.who.int/immunizations/CodeSystem/IMMZ.Ex</code></td><td style=\"white-space:nowrap\">  <a href=\"CodeSystem-IMMZ.Ex.html#IMMZ.Ex-brand\">brand</a></td><td>Example Brand</td></tr></table><hr/><p class=\"res-header-id\"><b>ValueSet #IMMZ.D.DE23</b></p><a name=\"QIMMZD13/IMMZ.D.DE23\"> </a><a name=\"hcQIMMZD13/IMMZ.D.DE23\"> </a><p>This value set expansion contains 1 concepts.</p><table class=\"codes\"><tr><td><b>System</b></td><td style=\"whi