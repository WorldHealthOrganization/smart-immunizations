           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Cholera dose 1 Due Date"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@dynamicValue: Cholera dose 1 Due Date\n@pseudocode: \"Date of birth\" + 2 years\n*/\ndefine \"Cholera dose 1 Due Date\":\n  if \"Cholera dose 1\" then Patient.birthDate + 2 years\n  else null"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 32
         ]
       ] ) ;
       fhir:url [
