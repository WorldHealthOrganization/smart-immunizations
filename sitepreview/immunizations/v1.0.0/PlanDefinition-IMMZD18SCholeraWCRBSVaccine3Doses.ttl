         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "IMMZD18SCholeraWCRBSVaccine3DosesLogic"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Cholera dose 1 Create"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Cholera dose 1 Create\n@create: For WC-rBS vaccine (Dukoral), 3 doses should be given to children 2–5 years of age, with an interval of 1-6 weeks between doses. If the interval since the last dose ≥ 6 weeks, restart the primary series.\n\nRevaccination for children aged 2–5 years: If more than 6 months have passed since completion of primary vaccination series, the primary series of 3 doses should be repeated.\n*/\ndefine \"Cholera dose 1 Create\":\n  if \"Cholera dose 1\"\n  then 'For WC-rBS vaccine (Dukoral), 3 doses should be given to children 2–5 years of age, with an interval of 1-6 weeks between doses. If the interval since the last dose ≥ 6 weeks, restart the primary series.\nRevaccination for children aged 2–5 years: If more than 6 months have passed since completion of primary vaccination series, the primary series of 3 doses should be repeated.' + '\nDue Date: ' + ToString(\"Cholera dose 1 Due Date\")\n  else ''"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
         fhir:value [
           a fhir:Integer ;
           fhir:v 33
         ]
       ] ) ;
       fhir:url [
         fhir:v "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition"^^xsd:anyURI ;
         fhir:l <http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "libraryName"^^xsd:anyURI ;
           fhir:l fhir:libraryName
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "IMMZCommon"
         ]
       ] [
         fhir:url [
           fhir:v "name"^^xsd:anyURI ;
           fhir:l fhir:name
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "getDose"
         ]
       ] [
         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/**\n * @description: Gets a given immunization from a list that matches the dose number\n */\ndefine fluent function getDose(immunization Immunization, doseNumber String):\n  immunization I where\n    exists( I.protocolApplied pa where pa.doseNumber = doseNumber )"
         ]
       ] [
         fhir:url [
           fhir:v "displaySequence"^^xsd:anyURI ;
           fhir:l fhir:displaySequence
         ] ;
