         fhir:value [
           a fhir:String ;
           fhir:v "define fluent function mostRecent(immunizations List<Immunization>):\n  Last(\n    immunizations I\n      sort by start of occurrence.toInterval()\n  )"
         ]
       ] [
         fhir:url [
