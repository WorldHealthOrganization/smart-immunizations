    </telecom>
  </contact>
  <description value="IMMZ.D18.S.Pneumococcal.3 doses schedule&#xA;3 primary doses (3p+0) schedule"/>
  <relatedArtifact>
    <type value="citation"/>
    <citation value="WHO recommendations for routine immunization - summary tables (January 2025)"/>
  </relatedArtifact>
  <library value="http://smart.who.int/immunizations/Library/IMMZD18SPneumococcal3DosesLogic"/>
  <action>
    <title value="Pneumococcal dose 1"/>
    <description value="Provision of the pneumococcal dose 1&#xA;Trigger event: Child's birth&#xA;Trigger pseudo: &#xA;Trigger date: &quot;Date of birth&quot;&#xA;Create condition: Pneumococcal dose 1 should be provided if the client is older than 6 weeks"/>
    <condition>
      <kind value="applicability"/>
      <expression>
        <description value="Pneumococcal dose 1"/>
        <language value="text/cql-identifier"/>
        <expression value="Pneumococcal dose 1"/>
      </expression>
