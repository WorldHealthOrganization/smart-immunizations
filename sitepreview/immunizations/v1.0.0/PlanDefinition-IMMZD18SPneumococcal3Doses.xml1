  <version value="1.0.0"/>
  <name value="IMMZD18SPneumococcal3Doses"/>
  <title value="IMMZ.D18.S.Pneumococcal.3 doses schedule"/>
  <type>
    <coding>
      <system value="http://terminology.hl7.org/CodeSystem/plan-definition-type"/>
