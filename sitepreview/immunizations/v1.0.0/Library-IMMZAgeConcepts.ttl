  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\">\n<div>\n    <table class=\"grid dict\">\n        \n        \n        <tr>\n            <th scope=\"row\"><b>Title: </b></th>\n            <td style=\"padding-left: 4px;\">IMMZAgeConcepts</td>\n        </tr>\n        \n\n        \n        \n        <tr>\n            <th scope=\"row\"><b>Id: </b></th>\n            <td style=\"padding-left: 4px;\">IMMZAgeConcepts</td>\n        </tr>\n        \n\n        \n        \n        <tr>\n            <th scope=\"row\"><b>Version: </b></th>\n            <td style=\"padding-left: 4px;\">1.0.0</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Url: </b></th>\n            <td style=\"padding-left: 4px;\"><a href=\"Library-IMMZAgeConcepts.html\">IMMZAgeConcepts</a></td>\n        </tr>\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Status: </b></th>\n            <td style=\"padding-left: 4px;\">draft</td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Type: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                    \n                        \n                        <p style=\"margin-bottom: 5px;\">\n                            <b>system: </b> <span><a href=\"http://terminology.hl7.org/7.1.0/CodeSystem-library-type.html\">http://terminology.hl7.org/CodeSystem/library-type</a></span>\n                        </p>\n                        \n                        \n                        <p style=\"margin-bottom: 5px;\">\n                            <b>code: </b> <span>logic-library</span>\n                        </p>\n                        \n                        \n                    \n                \n                \n            </td>\n        </tr>\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Date: </b></th>\n            <td style=\"padding-left: 4px;\">2026-04-09 14:18:30+0000</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Publisher: </b></th>\n            <td style=\"padding-left: 4px;\">WHO</td>\n        </tr>\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Description: </b></th>\n            <td style=\"padding-left: 4px;\"><div><p>This library defines concepts for ages and age ranges used throughout the Immunization CPG</p>\n</div></td>\n        </tr>\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n\n        \n        <tr>\n            <th scope=\"row\"><b>Related Artifacts: </b></th>\n            <td style=\"padding-left: 4px;\">\n                \n                \n                \n                <p><b>Dependencies</b></p>\n                <ul>\n                  \n                    <li><code>http://ohie.org/CodeSystem/iso-8601-derived-periods</code></li>\n                  \n                </ul>\n                \n                \n                \n                \n                \n            </td>\n        </tr>\n        \n\n        \n\n        \n\n        \n        \n        <tr>\n          <td colspan=\"2\">\n            <table>\n              <tr><th><a id=\"cql-content\"><b>Content: </b></a> text/cql</th></tr>\n              <tr><td><pre><code class=\"language-cql\">library IMMZAgeConcepts\n\ncodesystem \"ISO-8601-Derived Periods\": 'http://ohie.org/CodeSystem/iso-8601-derived-periods'\n\n// Age Groups for Vaccines for infants\ncode \"P0Y--P1Y\": 'P0Y--P1Y' from \"ISO-8601-Derived Periods\" display '&lt; 1 year'\ncode \"P1Y--P9999Y\": 'P1Y--P9999Y' from \"ISO-8601-Derived Periods\" display '&gt;= 1 year'\n\n// Age Groups for Vaccines for Toddlers\ncode \"P0Y--P2Y\": 'P0Y--P2Y' from \"ISO-8601-Derived Periods\" display '&lt; 2 years'\ncode \"P1Y--P2Y\": 'P1Y--P2Y' from \"ISO-8601-Derived Periods\" display '1 year'\ncode \"P2Y--P9999Y\": 'P2Y--P9999Y' from \"ISO-8601-Derived Periods\" display '&gt;= 2 years'\n\n// Age groups for newborns\ncode \"PT0H--PT24H\": 'PT0H--PT24H' from \"ISO-8601-Derived Periods\" display 'Within 24H of Birth'\ncode \"PT24H--P2W\": 'PT24H--P2W' from \"ISO-8601-Derived Periods\" display '&lt; 2 Weeks'\ncode \"P2W--P9999Y\": 'P2W--P9999Y' from \"ISO-8601-Derived Periods\" display '&gt;= 2 Weeks'\n\n// Age groups for children\ncode \"P1Y--P3Y\": 'P1Y--P3Y' from \"ISO-8601-Derived Periods\" display '1 - 2 years'\ncode \"P3Y--P6Y\": 'P3Y--P6Y' from \"ISO-8601-Derived Periods\" display '3 - 5 years'\ncode \"P6Y--P13Y\": 'P6Y--P13Y' from \"ISO-8601-Derived Periods\" display '6 - 12 years'\ncode \"P13Y--P9999Y\": 'P13Y--P9999Y' from \"ISO-8601-Derived Periods\" display '&gt;= 13 years'\n\n// Age groups for adolescent\ncode \"P0Y--P9Y\": 'P0Y--P9Y' from \"ISO-8601-Derived Periods\" display '&lt; 9 years'\ncode \"P9Y--P15Y\": 'P9Y--P15Y' from \"ISO-8601-Derived Periods\" display '9 - 14 years'\ncode \"P15Y--P9999Y\": 'P15Y--P9999Y' from \"ISO-8601-Derived Periods\" display '&gt;= 15 years'\n\n// Age groups\ncode \"P0Y--P18Y\": 'P0Y--P18Y' from \"ISO-8601-Derived Periods\" display '&lt; 18 years'\ncode \"P18Y--P30Y\": 'P18Y--P30Y' from \"ISO-8601-Derived Periods\" display '18 - 29 years'\ncode \"P30Y--P50Y\": 'P30Y--P50Y' from \"ISO-8601-Derived Periods\" display '30 - 49 years'\ncode \"P50Y--P70Y\": 'P50Y--P70Y' from \"ISO-8601-Derived Periods\" display '50 - 69 years'\ncode \"P70Y--P9999Y\": 'P70Y--P9999Y' from \"ISO-8601-Derived Periods\" display '&gt;= 70 years'\n\n// Age by year\ncode \"P2Y--P3Y\": 'P2Y--P3Y' from \"ISO-8601-Derived Periods\" display '2 years'\ncode \"P3Y--P4Y\": 'P3Y--P4Y' from \"ISO-8601-Derived Periods\" display '3 years'\ncode \"P4Y--P5Y\": 'P4Y--P5Y' from \"ISO-8601-Derived Periods\" display '4 years'\ncode \"P5Y--P6Y\": 'P5Y--P6Y' from \"ISO-8601-Derived Periods\" display '5 years'\ncode \"P6Y--P7Y\": 'P6Y--P7Y' from \"ISO-8601-Derived Periods\" display '6 years'\ncode \"P7Y--P8Y\": 'P7Y--P8Y' from \"ISO-8601-Derived Periods\" display '7 years'\ncode \"P8Y--P9Y\": 'P8Y--P9Y' from \"ISO-8601-Derived Periods\" display '8 years'\ncode \"P9Y--P10Y\": 'P9Y--P10Y' from \"ISO-8601-Derived Periods\" display '9 years'\ncode \"P10Y--P11Y\": 'P10Y--P11Y' from \"ISO-8601-Derived Periods\" display '10 years'\ncode \"P11Y--P12Y\": 'P11Y--P12Y' from \"ISO-8601-Derived Periods\" display '11 years'\ncode \"P12Y--P13Y\": 'P12Y--P13Y' from \"ISO-8601-Derived Periods\" display '12 years'\ncode \"P13Y--P14Y\": 'P13Y--P14Y' from \"ISO-8601-Derived Periods\" display '13 years'\ncode \"P14Y--P15Y\": 'P14Y--P15Y' from \"ISO-8601-Derived Periods\" display '14 years'\ncode \"P15Y--P16Y\": 'P15Y--P16Y' from \"ISO-8601-Derived Periods\" display '15 years'\ncode \"P16Y--P17Y\": 'P16Y--P17Y' from \"ISO-8601-Derived Periods\" display '16 years'\ncode \"P17Y--P18Y\": 'P17Y--P18Y' from \"ISO-8601-Derived Periods\" display '17 years'\ncode \"P18Y--P19Y\": 'P18Y--P19Y' from \"ISO-8601-Derived Periods\" display '18 years'\ncode \"P19Y--P20Y\": 'P19Y--P20Y' from \"ISO-8601-Derived Periods\" display '19 years'\ncode \"P20Y--P21Y\": 'P20Y--P21Y' from \"ISO-8601-Derived Periods\" display '20 years'\ncode \"P21Y--P22Y\": 'P21Y--P22Y' from \"ISO-8601-Derived Periods\" display '21 years'\ncode \"P22Y--P23Y\": 'P22Y--P23Y' from \"ISO-8601-Derived Periods\" display '22 years'\ncode \"P23Y--P24Y\": 'P23Y--P24Y' from \"ISO-8601-Derived Periods\" display '23 years'\ncode \"P24Y--P25Y\": 'P24Y--P25Y' from \"ISO-8601-Derived Periods\" display '24 years'\ncode \"P25Y--P26Y\": 'P25Y--P26Y' from \"ISO-8601-Derived Periods\" display '25 years'\ncode \"P26Y--P27Y\": 'P26Y--P27Y' from \"ISO-8601-Derived Periods\" display '26 years'\ncode \"P27Y--P28Y\": 'P27Y--P28Y' from \"ISO-8601-Derived Periods\" display '27 years'\ncode \"P28Y--P29Y\": 'P28Y--P29Y' from \"ISO-8601-Derived Periods\" display '28 years'\ncode \"P29Y--P30Y\": 'P29Y--P30Y' from \"ISO-8601-Derived Periods\" display