    "max" : "1",
    "type" : "Patient"
  },
  {
    "name" : "Client is not due for HPV vaccination Case 1",
    "use" : "out",
    "min" : 0,
    "max" : "1",
    "type" : "boolean"
  },
  {
    "name" : "Client is not due for HPV vaccination Case 2",
    "use" : "out",
