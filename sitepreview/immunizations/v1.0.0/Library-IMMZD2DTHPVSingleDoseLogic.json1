  },
  {
    "name" : "Client is not due for HPV vaccination Case 4",
    "use" : "out",
    "min" : 0,
    "max" : "1",
    "type" : "boolean"
  },
  {
    "name" : "Client is not due for HPV vaccination Case 5",
    "use" : "out",
    "min" : 0,
    "max" : "1",
    "type" : "boolean"
  },
