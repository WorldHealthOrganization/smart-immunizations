         fhir:url [
           fhir:v "statement"^^xsd:anyURI ;
           fhir:l fhir:statement
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "/*\n@output: Client is not due for IPV vaccination Case 1\n@pseudocode: \"Immunization recommendation status\" = \"Not due\"\n*/\ndefine \"Client is not due for IPV vaccination Case 1\":\n  Encounter.\"No poliovirus primary series doses were administered\"\n    and Encounter.\"Client's age is less than 8 weeks\""
         ]
