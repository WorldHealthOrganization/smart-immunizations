  fhir:PlanDefinition.action [
     fhir:index 0 ;
     fhir:Element.extension [
       fhir:index 0 ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/uv/cpg/StructureDefinition/cpg-rationale" ] ;
       fhir:Extension.valueMarkdown [ fhir:value "Because serious Hib disease occurs most commonly in children aged between 4 months and 18 months, \n  immunization should start from 6 weeks of age, or as early as possible thereafter. The interval between doses \n  should be at least 8 weeks if 2 primary doses are given. Hib-containing vaccine is not required for healthy \n  children aged over 5 years." ]
     ] ;
     fhir:PlanDefinition.action.title [ fhir:value "Determine if the client is due for HIb." ] ;
     fhir:PlanDefinition.action.description [ fhir:value "Determine if the client is due for HIb vaccine according to the national immunization protocol.\n2 primary doses with a booster dose (2p+1)" ] ;
