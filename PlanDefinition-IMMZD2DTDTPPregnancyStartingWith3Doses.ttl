  fhir:PlanDefinition.title [ fhir:value "IMMZ.D2.DT.DTP.Pregnancy starting with 3 doses"] ;
  fhir:PlanDefinition.type [
     fhir:CodeableConcept.coding [
       fhir:index 0 ;
