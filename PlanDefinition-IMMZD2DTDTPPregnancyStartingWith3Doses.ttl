         fhir:Extension.valueString [ fhir:value "Client is due for tetanus and diphtheria booster dose Case 3" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is due for tetanus and diphtheria booster dose Case 3\n@pseudocode: \"Immunization recommendation status\" = \"Due\" (where \"Vaccine type\" = \"Tetanus and diphtheria-containing vaccines\")\n*/\ndefine \"Client is due for tetanus and diphtheria booster dose Case 3\":\n  Encounter.\"Three DTP primary series doses were administered\"\n    and Encounter.\"Two tetanus and diphtheria booster doses were administered\"\n    and Encounter.\"The latest tetanus and diphtheria dose was administered more than 1 year ago\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
