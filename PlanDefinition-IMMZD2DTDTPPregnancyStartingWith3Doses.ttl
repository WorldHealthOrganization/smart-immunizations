       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTDTPPregnancyStartingWith3DosesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is not due for tetanus and diphtheria booster dose" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is not due for tetanus and diphtheria booster dose\n@pseudocode: \"Immunization recommendation status\" = \"Not due\" (where \"Vaccine type\" = \"Tetanus and diphtheria-containing vaccines\")\n*/\ndefine \"Client is not due for tetanus and diphtheria booster dose\":\n  \"Client is not due for tetanus and diphtheria booster dose Case 1\"\n    or \"Client is not due for tetanus and diphtheria booster dose Case 2\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "37"^^xsd:integer ]
       ] ;
