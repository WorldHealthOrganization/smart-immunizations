         fhir:Extension.valueString [ fhir:value "Client is due for tetanus and diphtheria booster dose" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is due for tetanus and diphtheria booster dose\n@pseudocode: \"Immunization recommendation status\" = \"Due\" (where \"Vaccine type\" = \"Tetanus and diphtheria-containing vaccines\")\n*/\ndefine \"Client is due for tetanus and diphtheria booster dose\":\n  \"Client is due for tetanus and diphtheria booster dose Case 1\"\n    or \"Client is due for tetanus and diphtheria booster dose Case 2\"\n    or \"Client is due for tetanus and diphtheria booster dose Case 3\"" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "33"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
     ], [
       fhir:index 41 ;
       fhir:Element.extension [
         fhir:index 0 ;
         fhir:Extension.url [ fhir:value "libraryName" ] ;
         fhir:Extension.valueString [ fhir:value "IMMZD2DTDTPPregnancyStartingWith3DosesLogic" ]
       ], [
         fhir:index 1 ;
         fhir:Extension.url [ fhir:value "name" ] ;
         fhir:Extension.valueString [ fhir:value "Client is due for tetanus and diphtheria booster dose Guidance" ]
       ], [
         fhir:index 2 ;
         fhir:Extension.url [ fhir:value "statement" ] ;
         fhir:Extension.valueString [ fhir:value "/*\n@output: Client is due for tetanus and diphtheria booster dose Guidance\n@guidance = Should vaccinate client with first tetanus and diphtheria booster dose as three DTP primary series doses were already administered and client is currently pregnant. \nCheck for contraindications.\n@guidance = Should vaccinate client with second tetanus and diphtheria booster dose as client is currently pregnant and the latest tetanus and diphtheria dose was administered more than 4 weeks ago. \nCheck for contraindications.\n@guidance = Should vaccinate client with third tetanus and diphtheria booster dose as the latest tetanus and diphtheria dose was administered more than 1 year ago. This dose should be administered at least 1 year after second booster dose or during next pregnancy. \nCheck for contraindications.\n*/\ndefine \"Client is due for tetanus and diphtheria booster dose Guidance\":\n  case\n    when \"Client is due for tetanus and diphtheria booster dose Case 1\" then 'Should vaccinate client with first tetanus and diphtheria booster dose as three DTP primary series doses were already administered and client is currently pregnant. \nCheck for contraindications.'\n    when \"Client is due for tetanus and diphtheria booster dose Case 2\" then 'Should vaccinate client with second tetanus and diphtheria booster dose as client is currently pregnant and the latest tetanus and diphtheria dose was administered more than 4 weeks ago. \nCheck for contraindications.'\n    when \"Client is due for tetanus and diphtheria booster dose Case 3\" then 'Should vaccinate client with third tetanus and diphtheria booster dose as the latest tetanus and diphtheria dose was administered more than 1 year ago. This dose should be administered at least 1 year after second booster dose or during next pregnancy. \nCheck for contraindications.'\n    else ''\n  end" ]
       ], [
         fhir:index 3 ;
         fhir:Extension.url [ fhir:value "displaySequence" ] ;
         fhir:Extension.valueInteger [ fhir:value "34"^^xsd:integer ]
       ] ;
       fhir:Extension.url [ fhir:value "http://hl7.org/fhir/StructureDefinition/cqf-logicDefinition" ]
